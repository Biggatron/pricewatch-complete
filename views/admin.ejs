          <% if (!recentEmailLogs || recentEmailLogs.length === 0) { %>
            <p>No email logs found.</p>
          <% } else { %>
            <div class="admin-table-scroll">
              <table class="admin-table">
                <thead>
                  <tr>
                    <th>ID</th>
                    <th>When</th>
                    <th>Type</th>
                    <th>Status</th>
                    <th>Track</th>
                    <th>Product</th>
                    <th>Subject</th>
                    <th>Original</th>
                    <th>Current</th>
                    <th>Email</th>
                    <th>Attempts</th>
                    <th>Next send</th>
                    <th>Delivered</th>
                    <th>Error</th>
                  </tr>

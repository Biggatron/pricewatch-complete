          <h2 class="admin-section-title">Failed track logs</h2>
          <p class="admin-subtitle">Filtered rows from <code>failed_track_logs</code></p>
          <form class="admin-filter-form" method="GET" action="/admin" autocomplete="off">
            <input type="hidden" name="tab" value="failed-tracks" autocomplete="off">
            <label>
              <span>Search</span>
              <input class="admin-input" type="text" name="failed_search" value="<%= failedTrackFilters.search %>" placeholder="Domain, URL or price" autocomplete="off" spellcheck="false">
            </label>
            <label>
              <span>Sort</span>
              <select class="admin-input" name="failed_sort">

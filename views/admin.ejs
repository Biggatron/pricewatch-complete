<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('./partials/head'); %>
  <link rel="stylesheet" href="/css/admin.css?v=20260403-3" type="text/css">
  <link rel="stylesheet" href="/css/track.css?v=20260405-2" type="text/css">
</head>
<body class="body-container">

<header>
  <%- include('./partials/header', { navItem: 'admin' }); %>
</header>

<main>
  <div class="content-container admin-container">
    <div class="space-between-row vertical-align-content admin-header">
      <div>
        <h1 class="admin-title">Admin Console</h1>
      </div>
    </div>

    <% if (accessDenied) { %>
      <div class="admin-panel">
        <p>You do not have access to this page.</p>
      </div>
    <% } else { %>
      <div class="admin-tabs" role="tablist" aria-label="Admin sections">
        <button class="admin-tab-button <%= activeTab === 'overview' ? 'is-active' : '' %>" type="button" data-tab-target="overview" role="tab" aria-selected="<%= activeTab === 'overview' ? 'true' : 'false' %>">Overview</button>
        <button class="admin-tab-button <%= activeTab === 'jobs' ? 'is-active' : '' %>" type="button" data-tab-target="jobs" role="tab" aria-selected="<%= activeTab === 'jobs' ? 'true' : 'false' %>">Job Schedule</button>
        <button class="admin-tab-button <%= activeTab === 'tracks' ? 'is-active' : '' %>" type="button" data-tab-target="tracks" role="tab" aria-selected="<%= activeTab === 'tracks' ? 'true' : 'false' %>">Track Manager</button>
        <button class="admin-tab-button <%= activeTab === 'domains' ? 'is-active' : '' %>" type="button" data-tab-target="domains" role="tab" aria-selected="<%= activeTab === 'domains' ? 'true' : 'false' %>">Domains</button>
        <button class="admin-tab-button <%= activeTab === 'config' ? 'is-active' : '' %>" type="button" data-tab-target="config" role="tab" aria-selected="<%= activeTab === 'config' ? 'true' : 'false' %>">Config</button>
        <button class="admin-tab-button <%= activeTab === 'cache' ? 'is-active' : '' %>" type="button" data-tab-target="cache" role="tab" aria-selected="<%= activeTab === 'cache' ? 'true' : 'false' %>">Cache</button>
        <button class="admin-tab-button <%= activeTab === 'service-logs' ? 'is-active' : '' %>" type="button" data-tab-target="service-logs" role="tab" aria-selected="<%= activeTab === 'service-logs' ? 'true' : 'false' %>">Service Logs</button>
        <button class="admin-tab-button <%= activeTab === 'failed-tracks' ? 'is-active' : '' %>" type="button" data-tab-target="failed-tracks" role="tab" aria-selected="<%= activeTab === 'failed-tracks' ? 'true' : 'false' %>">Failed Tracks</button>
        <button class="admin-tab-button <%= activeTab === 'emails' ? 'is-active' : '' %>" type="button" data-tab-target="emails" role="tab" aria-selected="<%= activeTab === 'emails' ? 'true' : 'false' %>">Emails</button>
      </div>

      <section class="admin-tab-panel <%= activeTab === 'overview' ? 'is-active' : '' %>" data-tab-panel="overview">
        <div class="admin-panel">
          <h2 class="admin-section-title">Job actions</h2>
          <div class="admin-inline-actions">
            <button class="btn" onclick="runAdminJob('crawler')">Update tracks</button>
            <button class="btn" onclick="runAdminJob('email_delivery')">Send pending emails</button>
            <button class="btn" onclick="runAdminJob('preview_cleanup')">Clean preview screenshots</button>
            <button class="btn admin-cancel-btn" onclick="clearRecentLogFile()">Clear recent log file</button>
          </div>
        </div>

        <div class="admin-panel">
          <h2 class="admin-section-title">Scheduled jobs</h2>
          <p class="admin-subtitle">Cron expressions are edited in the Config tab. Linux cron should invoke the dispatcher every minute.</p>
          <% if (!jobSettings || jobSettings.length === 0) { %>
            <p>No job configuration found.</p>
          <% } else { %>
            <div class="admin-table-scroll">
              <table class="admin-table">
                <thead>
                  <tr>
                    <th>Job</th>
                    <th>Enabled</th>
                    <th>Cron</th>
                    <th>Description</th>
                    <th>Action</th>
                  </tr>
                </thead>
                <tbody>
                  <% jobSettings.forEach((job) => { %>
                    <tr>
                      <td><%= job.displayName %></td>
                      <td><%= job.enabled ? 'Yes' : 'No' %></td>
                      <td><code><%= job.cronExpression %></code></td>
                      <td><%= job.description %></td>
                      <td><button class="btn btn-small" onclick="runAdminJob('<%= job.key %>')">Run now</button></td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>

        <div class="admin-panel">
          <h2 class="admin-section-title">Latest run summary</h2>
          <% if (!latestRun) { %>
            <p>No mass updates have been recorded yet.</p>
          <% } else { %>
            <div class="admin-stats-grid">
              <div class="admin-stat-card">
                <div class="admin-stat-label">Status</div>
                <div class="admin-stat-value"><%= latestRun.status %></div>
              </div>
              <div class="admin-stat-card">
                <div class="admin-stat-label">Tracks</div>
                <div class="admin-stat-value"><%= latestRun.track_count %></div>
              </div>
              <div class="admin-stat-card">
                <div class="admin-stat-label">HTML ok</div>
                <div class="admin-stat-value"><%= latestRun.html_success_count %></div>
              </div>
              <div class="admin-stat-card">
                <div class="admin-stat-label">HTML failed</div>
                <div class="admin-stat-value"><%= latestRun.html_failure_count %></div>
              </div>
              <div class="admin-stat-card">
                <div class="admin-stat-label">Unchanged</div>
                <div class="admin-stat-value"><%= latestRun.unchanged_count %></div>
              </div>
              <div class="admin-stat-card">
                <div class="admin-stat-label">Updated</div>
                <div class="admin-stat-value"><%= latestRun.updated_count %></div>
              </div>
              <div class="admin-stat-card">
                <div class="admin-stat-label">Lowered</div>
                <div class="admin-stat-value"><%= latestRun.lowered_count %></div>
              </div>
              <div class="admin-stat-card">
                <div class="admin-stat-label">Increased</div>
                <div class="admin-stat-value"><%= latestRun.increased_count %></div>
              </div>
              <div class="admin-stat-card">
                <div class="admin-stat-label">Inactive</div>
                <div class="admin-stat-value"><%= latestRun.inactive_count %></div>
              </div>
              <div class="admin-stat-card">
                <div class="admin-stat-label">Reactivated</div>
                <div class="admin-stat-value"><%= latestRun.reactivated_count %></div>
              </div>
              <div class="admin-stat-card">
                <div class="admin-stat-label">Errors</div>
                <div class="admin-stat-value"><%= latestRun.error_count %></div>
              </div>
              <div class="admin-stat-card">
                <div class="admin-stat-label">Duration</div>
                <div class="admin-stat-value"><%= latestRun.duration_ms %> ms</div>
              </div>
            </div>
            <p class="admin-subtitle">
              Started <%= new Date(latestRun.started_at).toLocaleString() %>.
              Biggest drop: <%= latestRun.biggest_drop_amount == null ? '-' : latestRun.biggest_drop_amount %>.
              Biggest increase: <%= latestRun.biggest_increase_amount == null ? '-' : latestRun.biggest_increase_amount %>.
            </p>
            <p><a href="/admin/runs/<%= latestRun.id %>">View latest run details</a></p>
          <% } %>
        </div>

        <div class="admin-panel">
          <h2 class="admin-section-title">Recent mass updates</h2>
          <% if (!recentRuns || recentRuns.length === 0) { %>
            <p>No mass updates logged.</p>
          <% } else { %>
            <div class="admin-table-scroll">
              <table class="admin-table">
                <thead>
                  <tr>
                    <th>When</th>
                    <th>Trigger</th>
                    <th>Status</th>
                    <th>Tracks</th>
                    <th>Updated</th>
                    <th>Errors</th>
                    <th>Details</th>
                  </tr>
                </thead>
                <tbody>
                  <% recentRuns.forEach((run) => { %>
                    <tr>
                      <td><%= new Date(run.started_at).toLocaleString() %></td>
                      <td><%= run.trigger_type %></td>
                      <td><%= run.status %></td>
                      <td><%= run.track_count %></td>
                      <td><%= run.updated_count %></td>
                      <td><%= run.error_count %></td>
                      <td><a href="/admin/runs/<%= run.id %>">View</a></td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>

        <div class="admin-panel">
          <h2 class="admin-section-title">Failed updates</h2>
          <% if (!failedUpdates || failedUpdates.length === 0) { %>
            <p>No failed updates logged.</p>
          <% } else { %>
            <div class="admin-table-scroll">
              <table class="admin-table">
                <thead>
                  <tr>
                    <th>When</th>
                    <th>Track</th>
                    <th>Stage</th>
                    <th>Error</th>
                    <th>Details</th>
                  </tr>
                </thead>
                <tbody>
                  <% failedUpdates.forEach((failure) => { %>
                    <tr>
                      <td><%= new Date(failure.created_at).toLocaleString() %></td>
                      <td><%= failure.track_id || '-' %></td>
                      <td><%= failure.stage %></td>
                      <td><%= failure.error_message %></td>
                      <td><a href="/admin/failed-updates/<%= failure.id %>">View</a></td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </section>

      <section class="admin-tab-panel <%= activeTab === 'jobs' ? 'is-active' : '' %>" data-tab-panel="jobs">
        <div class="admin-panel">
          <h2 class="admin-section-title">Job schedule</h2>
          <p class="admin-subtitle">The scheduler keeps one pending row per enabled job and records the actual execution result after dispatch runs.</p>
          <% if (!jobScheduleSummaries || jobScheduleSummaries.length === 0) { %>
            <p>No scheduled job data found.</p>
          <% } else { %>
            <div class="admin-table-scroll">
              <table class="admin-table">
                <thead>
                  <tr>
                    <th>Job</th>
                    <th>Enabled</th>
                    <th>Cron</th>
                    <th>Next execution</th>
                    <th>Last run</th>
                    <th>Last status</th>
                    <th>Error reason</th>
                  </tr>
                </thead>
                <tbody>
                  <% jobScheduleSummaries.forEach((job) => { %>
                    <tr>
                      <td><%= job.displayName %></td>
                      <td><%= job.enabled ? 'Yes' : 'No' %></td>
                      <td><code><%= job.cronExpression %></code></td>
                      <td>
                        <% if (!job.enabled) { %>
                          Disabled
                        <% } else if (!job.scheduleValid) { %>
                          Invalid schedule
                        <% } else if (job.nextRunAt) { %>
                          <%= new Date(job.nextRunAt).toLocaleString() %>
                        <% } else { %>
                          -
                        <% } %>
                      </td>
                      <td><%= job.lastRunAt ? new Date(job.lastRunAt).toLocaleString() : '-' %></td>
                      <td><%= job.lastStatus || '-' %></td>
                      <td><%= job.lastErrorReason || job.scheduleError || '-' %></td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </section>

      <section class="admin-tab-panel <%= activeTab === 'tracks' ? 'is-active' : '' %>" data-tab-panel="tracks">
        <div class="admin-panel">
          <h2 class="admin-section-title">Track manager</h2>
          <form class="admin-filter-form" method="GET" action="/admin" autocomplete="off">
            <input type="hidden" name="tab" value="tracks" autocomplete="off">
            <label>
              <span>Search</span>
              <input class="admin-input" type="text" name="track_search" value="<%= trackFilters.search %>" placeholder="Product, URL, user or email" autocomplete="off" spellcheck="false">
            </label>
            <label>
              <span>Active</span>
              <select class="admin-input" name="track_active">
                <option value="all" <%= trackFilters.active === 'all' ? 'selected' : '' %>>All</option>
                <option value="active" <%= trackFilters.active === 'active' ? 'selected' : '' %>>Active</option>
                <option value="inactive" <%= trackFilters.active === 'inactive' ? 'selected' : '' %>>Inactive</option>
              </select>
            </label>
            <label>
              <span>Deleted</span>
              <select class="admin-input" name="track_deleted">
                <option value="visible" <%= trackFilters.deleted === 'visible' ? 'selected' : '' %>>Visible only</option>
                <option value="deleted" <%= trackFilters.deleted === 'deleted' ? 'selected' : '' %>>Deleted only</option>
                <option value="all" <%= trackFilters.deleted === 'all' ? 'selected' : '' %>>All</option>
              </select>
            </label>
            <label>
              <span>Sort</span>
              <select class="admin-input" name="track_sort">
                <option value="modified_desc" <%= trackFilters.sort === 'modified_desc' ? 'selected' : '' %>>Recently changed</option>
                <option value="modified_asc" <%= trackFilters.sort === 'modified_asc' ? 'selected' : '' %>>Oldest change first</option>
                <option value="product_asc" <%= trackFilters.sort === 'product_asc' ? 'selected' : '' %>>Product A-Z</option>
                <option value="product_desc" <%= trackFilters.sort === 'product_desc' ? 'selected' : '' %>>Product Z-A</option>
                <option value="curr_price_desc" <%= trackFilters.sort === 'curr_price_desc' ? 'selected' : '' %>>Current price high-low</option>
                <option value="curr_price_asc" <%= trackFilters.sort === 'curr_price_asc' ? 'selected' : '' %>>Current price low-high</option>
                <option value="user_asc" <%= trackFilters.sort === 'user_asc' ? 'selected' : '' %>>User A-Z</option>
                <option value="user_desc" <%= trackFilters.sort === 'user_desc' ? 'selected' : '' %>>User Z-A</option>
              </select>
            </label>
            <label>
              <span>Max rows</span>
              <input class="admin-input" type="number" name="track_max_rows" min="1" max="500" value="<%= trackFilters.maxRows %>" autocomplete="off">
            </label>
            <div class="admin-filter-actions">
              <button class="btn btn-small" type="submit">Apply</button>
              <a class="btn btn-small admin-cancel-btn admin-link-button" href="/admin?tab=tracks">Reset</a>
            </div>
          </form>
          <% if (!tracks || tracks.length === 0) { %>
            <p>No tracks found.</p>
          <% } else { %>
            <div class="table-wrapper admin-track-wrapper">
              <table id="track-table" class="admin-track-table">
                <thead>
                  <tr>
                    <th>Product Name</th>
                    <th>User</th>
                    <th>Original Price</th>
                    <th>Current Price</th>
                    <th>Active</th>
                    <th class="hide-on-mobile">Change Date</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% tracks.forEach((track) => { %>
                    <tr class="admin-track-summary-row <%= track.deleted ? 'admin-track-summary-row-deleted' : '' %>" data-track-row="<%= track.id %>" data-track-toggle="<%= track.id %>" tabindex="0" role="button" aria-expanded="false">
                      <td>
                        <div>
                          <span class="admin-track-name"><%= track.product_name %></span>
                          <span class="admin-track-inline-id">#<%= track.id %></span>
                          <% if (track.deleted) { %>
                            <span class="admin-track-status-badge">Deleted</span>
                          <% } %>
                        </div>
                      </td>
                      <td>
                        <span
                          class="admin-user-chip"
                          tabindex="0"
                          data-tooltip="User: <%= track.user_name || 'Unknown user' %><%= track.email ? ' | ' + track.email : '' %>">
                          User #<%= track.user_id || '-' %>
                        </span>
                      </td>
                      <td>
                        <span class="field-display" data-display="orig_price"><%= track.orig_price %></span>
                        <input
                          class="admin-input field-edit display-none"
                          type="text"
                          inputmode="numeric"
                          step="1"
                          value="<%= track.orig_price %>"
                          autocomplete="off"
                          data-field="orig_price">
                      </td>
                      <td class="admin-price-cell" style="background-color: <%= track.curr_price < track.orig_price ? '#9dff9d' : track.curr_price > track.orig_price ? '#ff8d8d' : 'inherit' %>;">
                        <span class="field-display" data-display="curr_price"><%= track.curr_price %></span>
                        <input
                          class="admin-input field-edit display-none"
                          type="text"
                          inputmode="numeric"
                          step="1"
                          value="<%= track.curr_price %>"
                          autocomplete="off"
                          data-field="curr_price">
                      </td>
                      <td>
                        <span class="field-display" data-display="active"><%= track.active ? 'Yes' : 'No' %></span>
                        <label class="admin-checkbox-label field-edit display-none">
                          <input
                            type="checkbox"
                            autocomplete="off"
                            data-field="active"
                            <%= track.active ? 'checked' : '' %>>
                          <span><%= track.active ? 'Active' : 'Inactive' %></span>
                        </label>
                      </td>
                      <td class="hide-on-mobile"><%= track.last_modified_at ? new Date(track.last_modified_at).toLocaleDateString() : '-' %></td>
                      <td class="admin-actions-cell">
                        <div class="field-display admin-action-group admin-action-group-wrap">
                          <% if (!track.deleted) { %>
                            <button class="btn btn-small" onclick="editTrack(<%= track.id %>)">Edit</button>
                            <button class="btn btn-small" onclick="updateTrackNow(<%= track.id %>)">Update</button>
                          <% } else { %>
                            <button class="btn btn-small admin-restore-btn" onclick="restoreTrack(<%= track.id %>)">Undelete</button>
                          <% } %>
                          <button class="btn btn-small" onclick="viewTrackHtml(<%= track.id %>)">HTML</button>
                        </div>
                        <% if (!track.deleted) { %>
                          <div class="field-edit display-none admin-action-group">
                            <button class="btn btn-small" onclick="saveTrack(<%= track.id %>)">Save</button>
                            <button class="btn btn-small admin-cancel-btn" onclick="cancelEditTrack(<%= track.id %>)">Cancel</button>
                          </div>
                        <% } %>
                      </td>
                    </tr>
                    <tr class="admin-track-detail-row display-none" data-track-detail-row="<%= track.id %>">
                      <td colspan="7">
                        <div class="admin-track-detail-card">
                          <p class="admin-track-detail-link-row">
                            <strong>Original link:</strong>
                            <a href="<%= track.price_url %>" target="_blank" rel="noreferrer"><%= track.price_url %></a>
                          </p>
                          <% if (track.deleted) { %>
                            <p class="admin-track-subtext">This track has been soft deleted and is hidden from My tracks.</p>
                          <% } %>
                          <%- include('partials/track-history-graph', { track }); %>
                        </div>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </section>

      <section class="admin-tab-panel <%= activeTab === 'domains' ? 'is-active' : '' %>" data-tab-panel="domains">
        <div class="admin-panel">
          <h2 class="admin-section-title">Domain access profiles</h2>
          <p class="admin-subtitle">Filtered rows from <code>domain_access_profiles</code></p>
          <form class="admin-filter-form" method="GET" action="/admin" autocomplete="off">
            <input type="hidden" name="tab" value="domains" autocomplete="off">
            <label>
              <span>Search</span>
              <input class="admin-input" type="text" name="domain_search" value="<%= domainFilters.search %>" placeholder="Domain or mode" autocomplete="off" spellcheck="false">
            </label>
            <label>
              <span>Preview</span>
              <select class="admin-input" name="domain_preview_mode">
                <option value="all" <%= domainFilters.previewMode === 'all' ? 'selected' : '' %>>All</option>
                <option value="iframe" <%= domainFilters.previewMode === 'iframe' ? 'selected' : '' %>>Iframe</option>
                <option value="screenshot" <%= domainFilters.previewMode === 'screenshot' ? 'selected' : '' %>>Screenshot</option>
              </select>
            </label>
            <label>
              <span>Crawler</span>
              <select class="admin-input" name="domain_crawler_mode">
                <option value="all" <%= domainFilters.crawlerMode === 'all' ? 'selected' : '' %>>All</option>
                <option value="direct_html" <%= domainFilters.crawlerMode === 'direct_html' ? 'selected' : '' %>>Direct HTML</option>
                <option value="headless_browser" <%= domainFilters.crawlerMode === 'headless_browser' ? 'selected' : '' %>>Headless browser</option>
              </select>
            </label>
            <label>
              <span>Price lookup</span>
              <select class="admin-input" name="domain_price_lookup_mode">
                <option value="all" <%= domainFilters.priceLookupMode === 'all' ? 'selected' : '' %>>All</option>
                <option value="div_structure" <%= domainFilters.priceLookupMode === 'div_structure' ? 'selected' : '' %>>Div structure</option>
                <option value="string_match" <%= domainFilters.priceLookupMode === 'string_match' ? 'selected' : '' %>>String match</option>
              </select>
            </label>
            <label>
              <span>Sort</span>
              <select class="admin-input" name="domain_sort">
                <option value="updated_desc" <%= domainFilters.sort === 'updated_desc' ? 'selected' : '' %>>Recently updated</option>
                <option value="updated_asc" <%= domainFilters.sort === 'updated_asc' ? 'selected' : '' %>>Oldest updated</option>
                <option value="created_desc" <%= domainFilters.sort === 'created_desc' ? 'selected' : '' %>>Newest created</option>
                <option value="created_asc" <%= domainFilters.sort === 'created_asc' ? 'selected' : '' %>>Oldest created</option>
                <option value="domain_asc" <%= domainFilters.sort === 'domain_asc' ? 'selected' : '' %>>Domain A-Z</option>
                <option value="domain_desc" <%= domainFilters.sort === 'domain_desc' ? 'selected' : '' %>>Domain Z-A</option>
              </select>
            </label>
            <label>
              <span>Max rows</span>
              <input class="admin-input" type="number" name="domain_max_rows" min="1" max="500" value="<%= domainFilters.maxRows %>" autocomplete="off">
            </label>
            <div class="admin-filter-actions">
              <button class="btn btn-small" type="submit">Apply</button>
              <a class="btn btn-small admin-cancel-btn admin-link-button" href="/admin?tab=domains">Reset</a>
            </div>
          </form>
          <% if (!domainProfiles || domainProfiles.length === 0) { %>
            <p>No domain access profiles found.</p>
          <% } else { %>
            <div class="admin-table-scroll">
              <table class="admin-table">
                <thead>
                  <tr>
                    <th>ID</th>
                    <th>Domain</th>
                    <th>Preview</th>
                    <th>Crawler</th>
                    <th>Price lookup</th>
                    <th>Created</th>
                    <th>Updated</th>
                  </tr>
                </thead>
                <tbody>
                  <% domainProfiles.forEach((profile) => { %>
                    <tr>
                      <td><%= profile.id %></td>
                      <td><%= profile.domain || '-' %></td>
                      <td><%= profile.preview_mode || '-' %></td>
                      <td><%= profile.crawler_mode || '-' %></td>
                      <td><%= profile.price_lookup_mode || '-' %></td>
                      <td><%= profile.created_at ? new Date(profile.created_at).toLocaleString() : '-' %></td>
                      <td><%= profile.updated_at ? new Date(profile.updated_at).toLocaleString() : '-' %></td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </section>

      <section class="admin-tab-panel <%= activeTab === 'config' ? 'is-active' : '' %>" data-tab-panel="config">
        <div class="admin-panel">
          <h2 class="admin-section-title">Config table</h2>
          <p class="admin-subtitle">Database-backed application settings. Changes apply automatically where the app reads from <code>app_config</code>.</p>
          <% if (!appConfigs || appConfigs.length === 0) { %>
            <p>No config entries found.</p>
          <% } else { %>
            <div class="admin-table-scroll">
              <table class="admin-table admin-config-table">
                <thead>
                  <tr>
                    <th>Key</th>
                    <th>Type</th>
                    <th>Description</th>
                    <th>Allowed values</th>
                    <th>Current value</th>
                    <th>Action</th>
                  </tr>
                </thead>
                <tbody>
                  <% appConfigs.forEach((config) => { %>
                    <tr data-config-row="<%= config.config_key %>">
                      <td class="admin-config-key"><code><%= config.config_key %></code></td>
                      <td><%= config.data_type %></td>
                      <td><%= config.description || '-' %></td>
                      <td><%= config.value_help || '-' %></td>
                      <td>
                        <% if (config.data_type === 'boolean') { %>
                          <label class="admin-checkbox-label">
                            <input
                              type="checkbox"
                              autocomplete="off"
                              data-config-field="value"
                              <%= config.parsed_value ? 'checked' : '' %>>
                            <span><%= config.parsed_value ? 'Enabled' : 'Disabled' %></span>
                          </label>
                        <% } else if (config.config_key === 'email.transport_mode') { %>
                          <select class="admin-input" data-config-field="value">
                            <option value="smtp" <%= config.value === 'smtp' ? 'selected' : '' %>>SMTP</option>
                            <option value="ses" <%= config.value === 'ses' ? 'selected' : '' %>>Amazon SES</option>
                          </select>
                        <% } else { %>
                          <input
                            class="admin-input"
                            type="<%= config.data_type === 'integer' || config.data_type === 'number' ? 'number' : config.data_type === 'secret' ? 'password' : 'text' %>"
                            <%= config.data_type === 'integer' ? 'step="1"' : '' %>
                            value="<%= config.value == null ? '' : config.value %>"
                            autocomplete="<%= config.data_type === 'secret' ? 'new-password' : 'off' %>"
                            autocapitalize="off"
                            spellcheck="false"
                            data-config-field="value">
                        <% } %>
                      </td>
                      <td>
                        <button class="btn btn-small" onclick="saveConfig('<%= config.config_key %>')">Save</button>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </section>

      <section class="admin-tab-panel <%= activeTab === 'cache' ? 'is-active' : '' %>" data-tab-panel="cache">
        <div class="admin-panel">
          <h2 class="admin-section-title">Screenshot cache</h2>
          <p class="admin-subtitle">Cache metadata is stored in the database. Screenshot files live in <code><%= previewCacheSummary.screenshotDirectory %></code>.</p>
        </div>

        <div class="admin-panel">
          <h2 class="admin-section-title">Cached screenshots</h2>
          <% if (!previewCacheSummary.screenshotFiles || previewCacheSummary.screenshotFiles.length === 0) { %>
            <p>No cached screenshots found.</p>
          <% } else { %>
            <div class="admin-table-scroll">
              <table class="admin-table">
                <thead>
                  <tr>
                    <th>File</th>
                    <th>Source URL</th>
                    <th>Created</th>
                    <th>Last accessed</th>
                    <th>Expires</th>
                    <th>Size</th>
                  </tr>
                </thead>
                <tbody>
                  <% previewCacheSummary.screenshotFiles.forEach((entry) => { %>
                    <tr>
                      <td>
                        <% if (entry.fileExists) { %>
                          <a href="<%= entry.publicPath %>" target="_blank"><%= entry.fileName %></a>
                        <% } else { %>
                          <%= entry.fileName %> (missing)
                        <% } %>
                      </td>
                      <td class="admin-url-cell">
                        <% if (entry.sourceUrl) { %>
                          <a href="<%= entry.sourceUrl %>" target="_blank"><%= entry.sourceUrl %></a>
                        <% } else { %>
                          -
                        <% } %>
                      </td>
                      <td><%= entry.createdAt ? new Date(entry.createdAt).toLocaleString() : '-' %></td>
                      <td><%= entry.lastAccessedAt ? new Date(entry.lastAccessedAt).toLocaleString() : '-' %></td>
                      <td><%= entry.estimatedClearAt ? new Date(entry.estimatedClearAt).toLocaleString() : '-' %></td>
                      <td><%= entry.sizeBytes == null ? '-' : Math.round((entry.sizeBytes || 0) / 1024) + ' KB' %></td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </section>

      <section class="admin-tab-panel <%= activeTab === 'service-logs' ? 'is-active' : '' %>" data-tab-panel="service-logs">
        <div class="admin-panel admin-panel-fill">
          <h2 class="admin-section-title">Recent logs</h2>
          <p class="admin-subtitle">Service logs from <%= logFilePath %></p>

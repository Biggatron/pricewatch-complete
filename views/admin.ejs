<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('./partials/head'); %>
  <link rel="stylesheet" href="/css/admin.css?v=20260328-2" type="text/css">
  <link rel="stylesheet" href="/css/track.css?v=20260328-2" type="text/css">
</head>
<body class="body-container">

<header>
  <%- include('./partials/header', { navItem: 'admin' }); %>
</header>

<main>
  <div class="content-container admin-container">
    <div class="space-between-row vertical-align-content admin-header">
      <div>
        <h1 class="admin-title">Admin Console</h1>
      </div>
    </div>

    <% if (accessDenied) { %>
      <div class="admin-panel">
        <p>You do not have access to this page.</p>
      </div>
    <% } else { %>
      <div class="admin-tabs" role="tablist" aria-label="Admin sections">
        <button class="admin-tab-button <%= activeTab === 'overview' ? 'is-active' : '' %>" type="button" data-tab-target="overview" role="tab" aria-selected="<%= activeTab === 'overview' ? 'true' : 'false' %>">Overview</button>
        <button class="admin-tab-button <%= activeTab === 'tracks' ? 'is-active' : '' %>" type="button" data-tab-target="tracks" role="tab" aria-selected="<%= activeTab === 'tracks' ? 'true' : 'false' %>">Track Manager</button>
        <button class="admin-tab-button <%= activeTab === 'config' ? 'is-active' : '' %>" type="button" data-tab-target="config" role="tab" aria-selected="<%= activeTab === 'config' ? 'true' : 'false' %>">Config</button>
        <button class="admin-tab-button <%= activeTab === 'service-logs' ? 'is-active' : '' %>" type="button" data-tab-target="service-logs" role="tab" aria-selected="<%= activeTab === 'service-logs' ? 'true' : 'false' %>">Service Logs</button>
        <button class="admin-tab-button <%= activeTab === 'failed-tracks' ? 'is-active' : '' %>" type="button" data-tab-target="failed-tracks" role="tab" aria-selected="<%= activeTab === 'failed-tracks' ? 'true' : 'false' %>">Failed Tracks</button>
        <button class="admin-tab-button <%= activeTab === 'emails' ? 'is-active' : '' %>" type="button" data-tab-target="emails" role="tab" aria-selected="<%= activeTab === 'emails' ? 'true' : 'false' %>">Emails</button>
      </div>

      <section class="admin-tab-panel <%= activeTab === 'overview' ? 'is-active' : '' %>" data-tab-panel="overview">
        <div class="admin-panel">
          <h2 class="admin-section-title">Actions</h2>
          <div class="admin-inline-actions">
            <button class="btn" onclick="updateTracks()">Update tracks</button>
            <button class="btn" onclick="sendPendingEmails()">Send pending emails</button>
            <button class="btn admin-cancel-btn" onclick="clearRecentLogFile()">Clear recent log file</button>
          </div>
        </div>

        <div class="admin-panel">
          <h2 class="admin-section-title">Latest run summary</h2>
          <% if (!latestRun) { %>
            <p>No mass updates have been recorded yet.</p>
          <% } else { %>
            <div class="admin-stats-grid">
              <div class="admin-stat-card">
                <div class="admin-stat-label">Status</div>
                <div class="admin-stat-value"><%= latestRun.status %></div>
              </div>
              <div class="admin-stat-card">
                <div class="admin-stat-label">Tracks</div>
                <div class="admin-stat-value"><%= latestRun.track_count %></div>
              </div>
              <div class="admin-stat-card">
                <div class="admin-stat-label">HTML ok</div>
                <div class="admin-stat-value"><%= latestRun.html_success_count %></div>
              </div>
              <div class="admin-stat-card">
                <div class="admin-stat-label">HTML failed</div>
                <div class="admin-stat-value"><%= latestRun.html_failure_count %></div>
              </div>
              <div class="admin-stat-card">
                <div class="admin-stat-label">Unchanged</div>
                <div class="admin-stat-value"><%= latestRun.unchanged_count %></div>
              </div>
              <div class="admin-stat-card">
                <div class="admin-stat-label">Updated</div>
                <div class="admin-stat-value"><%= latestRun.updated_count %></div>
              </div>
              <div class="admin-stat-card">
                <div class="admin-stat-label">Lowered</div>
                <div class="admin-stat-value"><%= latestRun.lowered_count %></div>
              </div>
              <div class="admin-stat-card">
                <div class="admin-stat-label">Increased</div>
                <div class="admin-stat-value"><%= latestRun.increased_count %></div>
              </div>
              <div class="admin-stat-card">
                <div class="admin-stat-label">Inactive</div>
                <div class="admin-stat-value"><%= latestRun.inactive_count %></div>
              </div>
              <div class="admin-stat-card">
                <div class="admin-stat-label">Reactivated</div>
                <div class="admin-stat-value"><%= latestRun.reactivated_count %></div>
              </div>
              <div class="admin-stat-card">
                <div class="admin-stat-label">Errors</div>
                <div class="admin-stat-value"><%= latestRun.error_count %></div>
              </div>
              <div class="admin-stat-card">
                <div class="admin-stat-label">Duration</div>
                <div class="admin-stat-value"><%= latestRun.duration_ms %> ms</div>
              </div>
            </div>
            <p class="admin-subtitle">
              Started <%= new Date(latestRun.started_at).toLocaleString() %>.
              Biggest drop: <%= latestRun.biggest_drop_amount == null ? '-' : latestRun.biggest_drop_amount %>.
              Biggest increase: <%= latestRun.biggest_increase_amount == null ? '-' : latestRun.biggest_increase_amount %>.
            </p>
            <p><a href="/admin/runs/<%= latestRun.id %>">View latest run details</a></p>
          <% } %>
        </div>

        <div class="admin-panel">
          <h2 class="admin-section-title">Recent mass updates</h2>
          <% if (!recentRuns || recentRuns.length === 0) { %>
            <p>No mass updates logged.</p>
          <% } else { %>
            <div class="admin-table-scroll">
              <table class="admin-table">
                <thead>
                  <tr>
                    <th>When</th>
                    <th>Trigger</th>
                    <th>Status</th>
                    <th>Tracks</th>
                    <th>Updated</th>
                    <th>Errors</th>
                    <th>Details</th>
                  </tr>
                </thead>
                <tbody>
                  <% recentRuns.forEach((run) => { %>
                    <tr>
                      <td><%= new Date(run.started_at).toLocaleString() %></td>
                      <td><%= run.trigger_type %></td>
                      <td><%= run.status %></td>
                      <td><%= run.track_count %></td>
                      <td><%= run.updated_count %></td>
                      <td><%= run.error_count %></td>
                      <td><a href="/admin/runs/<%= run.id %>">View</a></td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>

        <div class="admin-panel">
          <h2 class="admin-section-title">Failed updates</h2>
          <% if (!failedUpdates || failedUpdates.length === 0) { %>
            <p>No failed updates logged.</p>
          <% } else { %>
            <div class="admin-table-scroll">
              <table class="admin-table">
                <thead>
                  <tr>
                    <th>When</th>
                    <th>Track</th>
                    <th>Stage</th>
                    <th>Error</th>
                    <th>Details</th>
                  </tr>
                </thead>
                <tbody>
                  <% failedUpdates.forEach((failure) => { %>
                    <tr>
                      <td><%= new Date(failure.created_at).toLocaleString() %></td>
                      <td><%= failure.track_id || '-' %></td>
                      <td><%= failure.stage %></td>
                      <td><%= failure.error_message %></td>
                      <td><a href="/admin/failed-updates/<%= failure.id %>">View</a></td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </section>

      <section class="admin-tab-panel <%= activeTab === 'tracks' ? 'is-active' : '' %>" data-tab-panel="tracks">
        <div class="admin-panel">
          <h2 class="admin-section-title">Track manager</h2>
          <form class="admin-filter-form" method="GET" action="/admin">
            <input type="hidden" name="tab" value="tracks">
            <label>
              <span>Search</span>
              <input class="admin-input" type="text" name="track_search" value="<%= trackFilters.search %>" placeholder="Product, URL, user or email">
            </label>
            <label>
              <span>Active</span>
              <select class="admin-input" name="track_active">
                <option value="all" <%= trackFilters.active === 'all' ? 'selected' : '' %>>All</option>
                <option value="active" <%= trackFilters.active === 'active' ? 'selected' : '' %>>Active</option>
                <option value="inactive" <%= trackFilters.active === 'inactive' ? 'selected' : '' %>>Inactive</option>
              </select>
            </label>
            <label>
              <span>Sort</span>
              <select class="admin-input" name="track_sort">
                <option value="modified_desc" <%= trackFilters.sort === 'modified_desc' ? 'selected' : '' %>>Recently changed</option>
                <option value="modified_asc" <%= trackFilters.sort === 'modified_asc' ? 'selected' : '' %>>Oldest change first</option>
                <option value="product_asc" <%= trackFilters.sort === 'product_asc' ? 'selected' : '' %>>Product A-Z</option>
                <option value="product_desc" <%= trackFilters.sort === 'product_desc' ? 'selected' : '' %>>Product Z-A</option>
                <option value="curr_price_desc" <%= trackFilters.sort === 'curr_price_desc' ? 'selected' : '' %>>Current price high-low</option>
                <option value="curr_price_asc" <%= trackFilters.sort === 'curr_price_asc' ? 'selected' : '' %>>Current price low-high</option>
                <option value="user_asc" <%= trackFilters.sort === 'user_asc' ? 'selected' : '' %>>User A-Z</option>
                <option value="user_desc" <%= trackFilters.sort === 'user_desc' ? 'selected' : '' %>>User Z-A</option>
              </select>
            </label>
            <label>
              <span>Max rows</span>
              <input class="admin-input" type="number" name="track_max_rows" min="1" max="500" value="<%= trackFilters.maxRows %>">
            </label>
            <div class="admin-filter-actions">
              <button class="btn btn-small" type="submit">Apply</button>
              <a class="btn btn-small admin-cancel-btn admin-link-button" href="/admin?tab=tracks">Reset</a>
            </div>
          </form>
          <% if (!tracks || tracks.length === 0) { %>
            <p>No tracks found.</p>
          <% } else { %>
            <div class="table-wrapper admin-track-wrapper">
              <table id="track-table" class="admin-track-table">
                <thead>
                  <tr>
                    <th>Product Name</th>
                    <th>User</th>
                    <th>Original Price</th>
                    <th>Current Price</th>
                    <th>Active</th>
                    <th class="hide-on-mobile">Change Date</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% tracks.forEach((track) => { %>
                    <tr data-track-row="<%= track.id %>">
                      <td>
                        <div>
                          <a href="<%= track.price_url %>" target="_blank"><%= track.product_name %></a>
                          <span class="admin-track-inline-id">#<%= track.id %></span>
                        </div>
                      </td>
                      <td>
                        <span
                          class="admin-user-chip"
                          tabindex="0"
                          data-tooltip="User: <%= track.user_name || 'Unknown user' %><%= track.email ? ' | ' + track.email : '' %>">
                          User #<%= track.user_id || '-' %>
                        </span>
                      </td>
                      <td>
                        <span class="field-display" data-display="orig_price"><%= track.orig_price %></span>
                        <input
                          class="admin-input field-edit display-none"
                          type="text"
                          inputmode="numeric"
                          step="1"
                          value="<%= track.orig_price %>"
                          data-field="orig_price">
                      </td>
                      <td class="admin-price-cell" style="background-color: <%= track.curr_price < track.orig_price ? '#9dff9d' : track.curr_price > track.orig_price ? '#ff8d8d' : 'inherit' %>;">
                        <span class="field-display" data-display="curr_price"><%= track.curr_price %></span>
                        <input
                          class="admin-input field-edit display-none"
                          type="text"
                          inputmode="numeric"
                          step="1"
                          value="<%= track.curr_price %>"
                          data-field="curr_price">
                      </td>
                      <td>
                        <span class="field-display" data-display="active"><%= track.active ? 'Yes' : 'No' %></span>
                        <label class="admin-checkbox-label field-edit display-none">
                          <input
                            type="checkbox"
                            data-field="active"
                            <%= track.active ? 'checked' : '' %>>
                          <span><%= track.active ? 'Active' : 'Inactive' %></span>
                        </label>
                      </td>
                      <td class="hide-on-mobile"><%= track.last_modified_at ? new Date(track.last_modified_at).toLocaleDateString() : '-' %></td>
                      <td class="admin-actions-cell">
                        <div class="field-display admin-action-group admin-action-group-wrap">
                          <button class="btn btn-small" onclick="editTrack(<%= track.id %>)">Edit</button>
                          <button class="btn btn-small" onclick="updateTrackNow(<%= track.id %>)">Update</button>
                          <button class="btn btn-small" onclick="viewTrackHtml(<%= track.id %>)">HTML</button>
                        </div>
                        <div class="field-edit display-none admin-action-group">
                          <button class="btn btn-small" onclick="saveTrack(<%= track.id %>)">Save</button>
                          <button class="btn btn-small admin-cancel-btn" onclick="cancelEditTrack(<%= track.id %>)">Cancel</button>
                        </div>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </section>

      <section class="admin-tab-panel <%= activeTab === 'config' ? 'is-active' : '' %>" data-tab-panel="config">
        <div class="admin-panel">
          <h2 class="admin-section-title">Config table</h2>
          <p class="admin-subtitle">Database-backed application settings. Changes apply automatically where the app reads from <code>app_config</code>.</p>
          <% if (!appConfigs || appConfigs.length === 0) { %>
            <p>No config entries found.</p>
          <% } else { %>
            <div class="admin-table-scroll">
              <table class="admin-table admin-config-table">
                <thead>
                  <tr>
                    <th>Key</th>
                    <th>Category</th>
                    <th>Type</th>
                    <th>Description</th>
                    <th>Allowed values</th>
                    <th>Current value</th>
                    <th>Action</th>
                  </tr>
                </thead>
                <tbody>
                  <% appConfigs.forEach((config) => { %>
                    <tr data-config-row="<%= config.config_key %>">
                      <td class="admin-config-key"><code><%= config.config_key %></code></td>
                      <td><%= config.category || '-' %></td>
                      <td><%= config.data_type %></td>
                      <td><%= config.description || '-' %></td>
                      <td><%= config.value_help || '-' %></td>
                      <td>
                        <% if (config.data_type === 'boolean') { %>
                          <label class="admin-checkbox-label">
                            <input
                              type="checkbox"
                              data-config-field="value"
                              <%= config.parsed_value ? 'checked' : '' %>>
                            <span><%= config.parsed_value ? 'Enabled' : 'Disabled' %></span>
                          </label>
                        <% } else if (config.config_key === 'email.transport_mode') { %>
                          <select class="admin-input" data-config-field="value">
                            <option value="smtp" <%= config.value === 'smtp' ? 'selected' : '' %>>SMTP</option>
                            <option value="ses" <%= config.value === 'ses' ? 'selected' : '' %>>Amazon SES</option>
                          </select>
                        <% } else { %>
                          <input
                            class="admin-input"
                            type="<%= config.data_type === 'integer' || config.data_type === 'number' ? 'number' : config.data_type === 'secret' ? 'password' : 'text' %>"
                            <%= config.data_type === 'integer' ? 'step="1"' : '' %>
                            value="<%= config.value == null ? '' : config.value %>"
                            data-config-field="value">
                        <% } %>
                      </td>
                      <td>
                        <button class="btn btn-small" onclick="saveConfig('<%= config.config_key %>')">Save</button>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </section>

      <section class="admin-tab-panel <%= activeTab === 'service-logs' ? 'is-active' : '' %>" data-tab-panel="service-logs">
        <div class="admin-panel admin-panel-fill">
          <h2 class="admin-section-title">Recent logs</h2>
          <p class="admin-subtitle">Service logs from <%= logFilePath %></p>
          <div class="admin-inline-actions">
            <button class="btn admin-cancel-btn" onclick="clearRecentLogFile()">Clear recent log file</button>
          </div>
          <% if (!logs || logs.length === 0) { %>
            <p>No logs have been written yet.</p>
          <% } else { %>
            <pre class="log-viewer admin-service-log-viewer" id="service-log-viewer"><%= logs.join('\n') %></pre>
          <% } %>
        </div>
      </section>

      <section class="admin-tab-panel <%= activeTab === 'failed-tracks' ? 'is-active' : '' %>" data-tab-panel="failed-tracks">
        <div class="admin-panel">
          <h2 class="admin-section-title">Failed track logs</h2>
          <p class="admin-subtitle">Filtered rows from <code>failed_track_logs</code></p>
          <form class="admin-filter-form" method="GET" action="/admin">
            <input type="hidden" name="tab" value="failed-tracks">
            <label>
              <span>Search</span>
              <input class="admin-input" type="text" name="failed_search" value="<%= failedTrackFilters.search %>" placeholder="Domain, URL or price">
            </label>
            <label>
              <span>Sort</span>
              <select class="admin-input" name="failed_sort">
                <option value="created_desc" <%= failedTrackFilters.sort === 'created_desc' ? 'selected' : '' %>>Newest first</option>
                <option value="created_asc" <%= failedTrackFilters.sort === 'created_asc' ? 'selected' : '' %>>Oldest first</option>
                <option value="domain_asc" <%= failedTrackFilters.sort === 'domain_asc' ? 'selected' : '' %>>Domain A-Z</option>
                <option value="domain_desc" <%= failedTrackFilters.sort === 'domain_desc' ? 'selected' : '' %>>Domain Z-A</option>
                <option value="price_desc" <%= failedTrackFilters.sort === 'price_desc' ? 'selected' : '' %>>Price high-low</option>
                <option value="price_asc" <%= failedTrackFilters.sort === 'price_asc' ? 'selected' : '' %>>Price low-high</option>
              </select>
            </label>
            <label>
              <span>Max rows</span>
              <input class="admin-input" type="number" name="failed_max_rows" min="1" max="500" value="<%= failedTrackFilters.maxRows %>">
            </label>
            <div class="admin-filter-actions">
              <button class="btn btn-small" type="submit">Apply</button>
              <a class="btn btn-small admin-cancel-btn admin-link-button" href="/admin?tab=failed-tracks">Reset</a>
            </div>
          </form>
          <% if (!recentFailedTrackLogs || recentFailedTrackLogs.length === 0) { %>
            <p>No failed track logs found.</p>
          <% } else { %>
            <div class="admin-table-scroll">
              <table class="admin-table">
                <thead>
                  <tr>
                    <th>ID</th>
                    <th>When</th>
                    <th>Price</th>
                    <th>Domain</th>
                    <th>URL</th>
                  </tr>
                </thead>
                <tbody>
                  <% recentFailedTrackLogs.forEach((logEntry) => { %>
                    <tr>
                      <td><%= logEntry.id %></td>
                      <td><%= logEntry.created_at ? new Date(logEntry.created_at).toLocaleString() : '-' %></td>
                      <td><%= logEntry.product_price || '-' %></td>
                      <td><%= logEntry.domain || '-' %></td>
                      <td class="admin-url-cell">
                        <% if (logEntry.product_url) { %>
                          <a href="<%= logEntry.product_url %>" target="_blank"><%= logEntry.product_url %></a>
                        <% } else { %>
                          -
                        <% } %>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </section>

      <section class="admin-tab-panel <%= activeTab === 'emails' ? 'is-active' : '' %>" data-tab-panel="emails">
        <div class="admin-panel">
          <h2 class="admin-section-title">Email logs</h2>
          <p class="admin-subtitle">Filtered rows from <code>email_logs</code></p>
          <div class="admin-inline-actions">
            <button class="btn btn-small" onclick="sendPendingEmails()">Send pending emails</button>
          </div>
          <form class="admin-filter-form" method="GET" action="/admin">
            <input type="hidden" name="tab" value="emails">
            <label>
              <span>Search</span>
              <input class="admin-input" type="text" name="email_search" value="<%= emailFilters.search %>" placeholder="Product, email, subject or error">
            </label>
            <label>
              <span>Status</span>
              <select class="admin-input" name="email_status">
                <option value="all" <%= emailFilters.status === 'all' ? 'selected' : '' %>>All</option>
                <option value="pending" <%= emailFilters.status === 'pending' ? 'selected' : '' %>>Pending</option>
                <option value="sent" <%= emailFilters.status === 'sent' ? 'selected' : '' %>>Sent</option>
                <option value="undeliverable" <%= emailFilters.status === 'undeliverable' ? 'selected' : '' %>>Undeliverable</option>
                <option value="skipped_disabled" <%= emailFilters.status === 'skipped_disabled' ? 'selected' : '' %>>Skipped disabled</option>
                <option value="skipped_missing_config" <%= emailFilters.status === 'skipped_missing_config' ? 'selected' : '' %>>Skipped missing config</option>
              </select>
            </label>
            <label>
              <span>Type</span>
              <select class="admin-input" name="email_type">
                <option value="all" <%= emailFilters.emailType === 'all' ? 'selected' : '' %>>All</option>
                <option value="price_change" <%= emailFilters.emailType === 'price_change' ? 'selected' : '' %>>Price change</option>
                <option value="track_inactive" <%= emailFilters.emailType === 'track_inactive' ? 'selected' : '' %>>Track inactive</option>
                <option value="generic" <%= emailFilters.emailType === 'generic' ? 'selected' : '' %>>Generic</option>
              </select>
            </label>
            <label>
              <span>Sort</span>
              <select class="admin-input" name="email_sort">
                <option value="created_desc" <%= emailFilters.sort === 'created_desc' ? 'selected' : '' %>>Newest first</option>
                <option value="created_asc" <%= emailFilters.sort === 'created_asc' ? 'selected' : '' %>>Oldest first</option>
                <option value="status_asc" <%= emailFilters.sort === 'status_asc' ? 'selected' : '' %>>Status A-Z</option>
                <option value="status_desc" <%= emailFilters.sort === 'status_desc' ? 'selected' : '' %>>Status Z-A</option>
                <option value="attempts_desc" <%= emailFilters.sort === 'attempts_desc' ? 'selected' : '' %>>Attempts high-low</option>
                <option value="attempts_asc" <%= emailFilters.sort === 'attempts_asc' ? 'selected' : '' %>>Attempts low-high</option>
                <option value="email_asc" <%= emailFilters.sort === 'email_asc' ? 'selected' : '' %>>Email A-Z</option>
                <option value="email_desc" <%= emailFilters.sort === 'email_desc' ? 'selected' : '' %>>Email Z-A</option>
              </select>
            </label>
            <label>
              <span>Max rows</span>
              <input class="admin-input" type="number" name="email_max_rows" min="1" max="500" value="<%= emailFilters.maxRows %>">
            </label>
            <div class="admin-filter-actions">
              <button class="btn btn-small" type="submit">Apply</button>
              <a class="btn btn-small admin-cancel-btn admin-link-button" href="/admin?tab=emails">Reset</a>
            </div>
          </form>
          <% if (!recentEmailLogs || recentEmailLogs.length === 0) { %>
            <p>No email logs found.</p>
          <% } else { %>
            <div class="admin-table-scroll">
              <table class="admin-table">
                <thead>
                  <tr>
                    <th>ID</th>
                    <th>When</th>
                    <th>Type</th>
                    <th>Status</th>
                    <th>Track</th>
                    <th>Product</th>
                    <th>Subject</th>
                    <th>Original</th>
                    <th>Current</th>
                    <th>Email</th>
                    <th>Attempts</th>
                    <th>Delivered</th>
                    <th>Error</th>
                  </tr>
                </thead>
                <tbody>
                  <% recentEmailLogs.forEach((logEntry) => { %>
                    <tr>
                      <td><%= logEntry.id %></td>
                      <td><%= logEntry.created_at ? new Date(logEntry.created_at).toLocaleString() : '-' %></td>
                      <td><%= logEntry.email_type || 'generic' %></td>
                      <td><%= logEntry.effective_status || logEntry.status || (logEntry.delivered ? 'sent' : 'pending') %></td>
                      <td><%= logEntry.track_id || '-' %></td>
                      <td><%= logEntry.product_name || '-' %></td>
                      <td><%= logEntry.subject || '-' %></td>
                      <td><%= logEntry.orig_price == null ? '-' : logEntry.orig_price %></td>
                      <td><%= logEntry.curr_price == null ? '-' : logEntry.curr_price %></td>
                      <td><%= logEntry.email || '-' %></td>
                      <td><%= logEntry.attempt_count == null ? 0 : logEntry.attempt_count %></td>
                      <td><%= logEntry.delivered ? 'Yes' : 'No' %></td>
                      <td><%= logEntry.error_message || '-' %></td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </section>
    <% } %>
  </div>
</main>

<div class="admin-modal display-none" id="html-modal">
  <div class="admin-modal-backdrop" onclick="closeHtmlModal()"></div>
  <div class="admin-modal-content">
    <div class="space-between-row vertical-align-content">
      <div>
        <h2 class="admin-section-title" id="html-modal-title">Track HTML</h2>
        <p class="admin-subtitle" id="html-modal-url"></p>
      </div>
      <button class="btn btn-small admin-cancel-btn" onclick="closeHtmlModal()">Close</button>
    </div>
    <pre class="log-viewer html-viewer" id="html-modal-content">Loading...</pre>
  </div>
</div>

<footer>
  <%- include('./partials/footer'); %>
</footer>

<script>
  document.querySelectorAll('[data-tab-target]').forEach((tabButton) => {
    tabButton.addEventListener('click', () => {
      const target = tabButton.dataset.tabTarget;
      const url = new URL(window.location.href);
      url.searchParams.set('tab', target);
      window.location.href = url.toString();
    });
  });

  async function updateTracks() {
    try {
      const response = await fetch('/track/update-prices', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json; charset=UTF-8'
        }
      });

      if (response.status === 200) {
        showToast('Track update job started');
      } else if (response.status === 401) {
        window.location.href = '/auth/login';
      } else if (response.status === 403) {
        showToast('Admin access required');
      } else {
        showToast('Something went wrong');
      }
    } catch (error) {
      console.log(error);
      showToast('Something went wrong');
    }
  }

  async function clearRecentLogFile() {
    const confirmed = window.confirm('Clear the recent log file?');
    if (!confirmed) {
      return;
    }

    try {
      const response = await fetch('/admin/logs/clear', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json; charset=UTF-8'
        }
      });

      const body = await response.json().catch(() => null);
      if (!response.ok) {
        showToast(body && body.error ? body.error : 'Failed to clear log file');
        return;
      }

      showToast('Log file cleared');

      const url = new URL(window.location.href);
      url.searchParams.set('tab', 'service-logs');
      window.location.href = url.toString();
    } catch (error) {
      console.log(error);
      showToast('Failed to clear log file');
    }
  }

  async function sendPendingEmails() {
    try {
      const response = await fetch('/admin/emails/send-pending', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json; charset=UTF-8'
        }
      });

      const body = await response.json().catch(() => null);
      if (!response.ok) {
        showToast(body && body.error ? body.error : 'Failed to send pending emails');
        return;
      }

      const summary = body && body.summary ? body.summary : {};
      showToast(
        `Pending emails processed: ${summary.sentCount || 0} sent, ${summary.undeliverableCount || 0} undeliverable, ${summary.skippedCount || 0} skipped`
      );

      const url = new URL(window.location.href);
      url.searchParams.set('tab', 'emails');
      window.location.href = url.toString();
    } catch (error) {
      console.log(error);
      showToast('Failed to send pending emails');
    }
  }

  async function saveTrack(trackId) {
    const row = document.querySelector(`[data-track-row="${trackId}"]`);
    if (!row) {
      showToast('Track row not found');
      return;
    }

    const origPrice = row.querySelector('[data-field="orig_price"]').value;
    const currPrice = row.querySelector('[data-field="curr_price"]').value;
    const active = row.querySelector('[data-field="active"]').checked;

    try {
      const response = await fetch(`/admin/tracks/${trackId}`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json; charset=UTF-8'
        },
        body: JSON.stringify({
          orig_price: origPrice,
          curr_price: currPrice,
          active
        })
      });

      if (response.ok) {
        const label = row.querySelector('.admin-checkbox-label span');
        if (label) {
          label.textContent = active ? 'Active' : 'Inactive';
        }
        row.querySelector('[data-display="orig_price"]').textContent = origPrice;
        row.querySelector('[data-display="curr_price"]').textContent = currPrice;
        row.querySelector('[data-display="active"]').textContent = active ? 'Yes' : 'No';
        const currPriceCell = row.querySelector('.admin-price-cell');
        if (currPriceCell) {
          currPriceCell.style.backgroundColor =
            Number(currPrice) < Number(origPrice) ? '#9dff9d' :
            Number(currPrice) > Number(origPrice) ? '#ff8d8d' :
            'inherit';
        }
        toggleTrackEditMode(trackId, false);
        showToast(`Track ${trackId} updated`);
      } else {
        const body = await response.json().catch(() => null);
        showToast(body && body.error ? body.error : 'Failed to update track');
      }
    } catch (error) {
      console.log(error);
      showToast('Failed to update track');
    }
  }

  async function updateTrackNow(trackId) {
    try {
      const response = await fetch(`/admin/tracks/${trackId}/update-now`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json; charset=UTF-8'
        }
      });

      const body = await response.json().catch(() => null);
      if (!response.ok) {
        showToast(body && body.error ? body.error : 'Failed to update track');
        return;
      }

      const result = body.result || {};
      const row = document.querySelector(`[data-track-row="${trackId}"]`);
      if (row && result.currentPrice != null) {
        row.querySelector('[data-display="curr_price"]').textContent = result.currentPrice;
        const origPrice = row.querySelector('[data-display="orig_price"]').textContent.trim();
        const currPriceCell = row.querySelector('.admin-price-cell');
        if (currPriceCell) {
          currPriceCell.style.backgroundColor =
            Number(result.currentPrice) < Number(origPrice) ? '#9dff9d' :
            Number(result.currentPrice) > Number(origPrice) ? '#ff8d8d' :
            'inherit';
        }
      }

      if (row && typeof result.markedInactive === 'boolean') {
        row.querySelector('[data-display="active"]').textContent = result.markedInactive ? 'No' : 'Yes';
      }

      showToast(`Track ${trackId} updated: ${result.status || 'done'}`);
    } catch (error) {
      console.log(error);
      showToast('Failed to update track');
    }
  }

  async function saveConfig(configKey) {
    const row = document.querySelector(`[data-config-row="${CSS.escape(configKey)}"]`);
    if (!row) {
      showToast('Config row not found');
      return;
    }

    const input = row.querySelector('[data-config-field="value"]');
    const value = input.type === 'checkbox' ? input.checked : input.value;

    try {
      const response = await fetch('/admin/config', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json; charset=UTF-8'
        },
        body: JSON.stringify({
          config_key: configKey,
          value
        })
      });

      const body = await response.json().catch(() => null);
      if (!response.ok) {
        showToast(body && body.error ? body.error : 'Failed to update config');
        return;
      }

      if (input.type === 'checkbox') {
        const label = row.querySelector('.admin-checkbox-label span');
        if (label) {
          label.textContent = input.checked ? 'Enabled' : 'Disabled';
        }
      }

      showToast(`Config updated: ${configKey}`);
    } catch (error) {
      console.log(error);
      showToast('Failed to update config');
    }
  }

  async function viewTrackHtml(trackId) {
    const modal = document.getElementById('html-modal');
    const title = document.getElementById('html-modal-title');
    const url = document.getElementById('html-modal-url');
    const content = document.getElementById('html-modal-content');

    modal.classList.remove('display-none');
    title.textContent = `Track HTML #${trackId}`;
    url.textContent = '';
    content.textContent = 'Loading...';

    try {
      const response = await fetch(`/admin/tracks/${trackId}/html`);
      const body = await response.json().catch(() => null);

      if (!response.ok) {
        content.textContent = body && body.error ? body.error : 'Failed to load HTML';
        return;
      }

      title.textContent = body.productName || `Track HTML #${trackId}`;
      url.textContent = body.url || '';
      content.textContent = body.html || '';
    } catch (error) {
      console.log(error);
      content.textContent = 'Failed to load HTML';
    }
  }

  function closeHtmlModal() {
    document.getElementById('html-modal').classList.add('display-none');
  }

  function editTrack(trackId) {
    toggleTrackEditMode(trackId, true);
  }

  function cancelEditTrack(trackId) {
    const row = document.querySelector(`[data-track-row="${trackId}"]`);
    if (!row) {
      return;
    }

    row.querySelector('[data-field="orig_price"]').value = row.querySelector('[data-display="orig_price"]').textContent.trim();
    row.querySelector('[data-field="curr_price"]').value = row.querySelector('[data-display="curr_price"]').textContent.trim();

    const activeDisplay = row.querySelector('[data-display="active"]').textContent.trim();
    row.querySelector('[data-field="active"]').checked = activeDisplay === 'Yes';

    const label = row.querySelector('.admin-checkbox-label span');
    if (label) {
      label.textContent = activeDisplay === 'Yes' ? 'Active' : 'Inactive';
    }

    toggleTrackEditMode(trackId, false);
  }

  function toggleTrackEditMode(trackId, isEditing) {
    const row = document.querySelector(`[data-track-row="${trackId}"]`);
    if (!row) {
      return;
    }

    row.querySelectorAll('.field-display').forEach((el) => {
      el.classList.toggle('display-none', isEditing);
    });

    row.querySelectorAll('.field-edit').forEach((el) => {
      el.classList.toggle('display-none', !isEditing);
    });
  }

  document.querySelectorAll('.admin-user-chip').forEach((chip) => {
    chip.addEventListener('click', (event) => {
      event.stopPropagation();
      const isOpen = chip.classList.contains('tooltip-open');

      document.querySelectorAll('.admin-user-chip.tooltip-open').forEach((openChip) => {
        openChip.classList.remove('tooltip-open');
      });

      if (!isOpen) {
        chip.classList.add('tooltip-open');
      }
    });

    chip.addEventListener('blur', () => {
      chip.classList.remove('tooltip-open');
    });
  });

  document.addEventListener('click', () => {
    document.querySelectorAll('.admin-user-chip.tooltip-open').forEach((chip) => {
      chip.classList.remove('tooltip-open');
    });
  });

  const serviceLogViewer = document.getElementById('service-log-viewer');
  if (serviceLogViewer) {
    serviceLogViewer.scrollTop = serviceLogViewer.scrollHeight;
  }
</script>

</body>
</html>

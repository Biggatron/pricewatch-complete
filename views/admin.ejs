      <section class="admin-tab-panel <%= activeTab === 'emails' ? 'is-active' : '' %>" data-tab-panel="emails">
        <div class="admin-panel">
          <h2 class="admin-section-title">Template tester</h2>
          <p class="admin-subtitle">Choose a template, tweak the parameters, and send a real test email using the active transport settings.</p>
          <div class="admin-filter-form">
            <label>
              <span>Template</span>
              <select class="admin-input" id="email-template-select">
                <option value="">Choose template</option>
                <% emailTemplateTestDefinitions.forEach((templateDefinition) => { %>
                  <option value="<%= templateDefinition.key %>"><%= templateDefinition.label %></option>
                <% }); %>
              </select>
            </label>
          </div>
          <p class="admin-template-description" id="email-template-description">Select a template to load its test parameters.</p>
          <div class="admin-template-fields" id="email-template-fields"></div>
          <div class="admin-inline-actions">
            <button class="btn btn-small" type="button" id="email-template-send-button" onclick="sendTemplateTestEmail()" disabled>Send test email</button>
          </div>
        </div>

        <div class="admin-panel">
          <h2 class="admin-section-title">Email logs</h2>
          <p class="admin-subtitle">Filtered rows from <code>email_logs</code></p>
          <div class="admin-inline-actions">
            <button class="btn btn-small" onclick="sendPendingEmails()">Send pending emails</button>
          </div>
          <form class="admin-filter-form" method="GET" action="/admin" autocomplete="off">
            <input type="hidden" name="tab" value="emails" autocomplete="off">
            <label>
              <span>Search</span>
              <input class="admin-input" type="text" name="email_search" value="<%= emailFilters.search %>" placeholder="Product, email, subject or error" autocomplete="off" spellcheck="false">
            </label>
            <label>
              <span>Status</span>
              <select class="admin-input" name="email_status">
                <option value="all" <%= emailFilters.status === 'all' ? 'selected' : '' %>>All</option>
                <option value="pending" <%= emailFilters.status === 'pending' ? 'selected' : '' %>>Pending</option>
                <option value="sent" <%= emailFilters.status === 'sent' ? 'selected' : '' %>>Sent</option>
                <option value="undeliverable" <%= emailFilters.status === 'undeliverable' ? 'selected' : '' %>>Undeliverable</option>
                <option value="skipped_disabled" <%= emailFilters.status === 'skipped_disabled' ? 'selected' : '' %>>Skipped disabled</option>
                <option value="skipped_missing_config" <%= emailFilters.status === 'skipped_missing_config' ? 'selected' : '' %>>Skipped missing config</option>
              </select>
            </label>
            <label>
              <span>Type</span>
              <select class="admin-input" name="email_type">
                <option value="all" <%= emailFilters.emailType === 'all' ? 'selected' : '' %>>All</option>
                <option value="price_change" <%= emailFilters.emailType === 'price_change' ? 'selected' : '' %>>Price change</option>
                <option value="track_inactive" <%= emailFilters.emailType === 'track_inactive' ? 'selected' : '' %>>Track inactive</option>
                <option value="email_verification" <%= emailFilters.emailType === 'email_verification' ? 'selected' : '' %>>Email verification</option>
                <option value="password_reset" <%= emailFilters.emailType === 'password_reset' ? 'selected' : '' %>>Password reset</option>

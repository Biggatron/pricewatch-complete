<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('./partials/head'); %>
</head>
<body class="body-container">

<header>
  <%- include('./partials/header', {navItem: 'login'}); %>
</header>

<main class="themed-main">
  <section class="page-shell page-shell-narrow">
    <div class="page-card page-card-split">
      <div class="page-copy">
        <p class="page-kicker">Account recovery</p>
        <h1 class="page-title">Reset your password</h1>
        <p class="page-intro">
          Enter the email address tied to your account and we will send you a recovery link.
        </p>
      </div>

      <div class="page-card-panel">
        <div class="theme-form">
          <label class="theme-field" for="email">
            <span class="theme-label">Email</span>
            <input class="theme-input" id="email" type="email" autocomplete="email" placeholder="you@example.com">
          </label>

          <p id="forgot-password-status" class="theme-status <%= message ? 'theme-status-success' : 'display-none' %>"><%= message || '' %></p>

          <button class="btn-google-blue" type="button" onClick="sendRecoveryEmail()">Send recovery email</button>
        </div>

        <div class="theme-links">
          <p><a class="text-link" href="/auth/login">Back to login</a></p>
        </div>
      </div>
    </div>
  </section>
</main>

<footer>
  <%- include('./partials/footer'); %>
</footer>

</body>
</html>

<script>
  let loaderEl = document.getElementById('loader');
  let forgotPasswordStatusEl = document.getElementById('forgot-password-status');

  function showLoader() {
    loaderEl.classList.remove('display-none');
  }

  function hideLoader() {
    loaderEl.classList.add('display-none');
  }

  function setForgotPasswordStatus(message, type = 'success') {
    forgotPasswordStatusEl.innerText = message || '';
    forgotPasswordStatusEl.classList.toggle('display-none', !message);
    forgotPasswordStatusEl.classList.toggle('theme-status-success', Boolean(message) && type === 'success');
    forgotPasswordStatusEl.classList.toggle('theme-status-error', Boolean(message) && type === 'error');
  }

  function sendRecoveryEmail() {
    const email = document.getElementById('email').value;

    setForgotPasswordStatus('');

    showLoader();
    postData('/auth/forgot-password', { email }).then((response) => {
      hideLoader();
      setForgotPasswordStatus(response.message, 'success');
    }).catch((error) => {
      hideLoader();
      setForgotPasswordStatus(error, 'error');
    });
  }
</script>

<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('./partials/head'); %>
</head>
<body class="body-container">

<header>
  <%- include('./partials/header', {navItem: 'login'}); %>
</header>

<main class="themed-main">
  <section class="page-shell page-shell-narrow">
    <div class="page-card page-card-split">
      <div class="page-copy">
        <p class="page-kicker">Welcome back</p>
        <h1 class="page-title">Log in to your watchlist</h1>
        <p class="page-intro">
          Review recent price movement, open your tracked products, and stay on top of the deals worth waiting for.
        </p>

        <div class="page-stat-grid">
          <article class="page-stat-card">
            <span class="page-stat-label">One dashboard</span>
            <strong class="page-stat-value">See everything you are tracking in one place</strong>
          </article>
          <article class="page-stat-card">
            <span class="page-stat-label">Fast updates</span>
            <strong class="page-stat-value">Catch drops, steady prices, and increases at a glance</strong>
          </article>
        </div>
      </div>

      <div class="page-card-panel">
        <a class="google-btn" href="/auth/google">
          <span class="google-icon-wrapper">
            <img class="google-icon" src="/images/google_logo.svg" alt="">
          </span>
          <span class="btn-text">Continue with Google</span>
        </a>

        <div class="auth-or">or use email</div>

        <div class="theme-form">
          <label class="theme-field" for="email">
            <span class="theme-label">Email</span>
            <input class="theme-input" id="email" type="email" autocomplete="email" placeholder="you@example.com">
          </label>

          <label class="theme-field" for="password">
            <span class="theme-label">Password</span>
            <input class="theme-input" id="password" type="password" autocomplete="current-password" placeholder="Enter your password">
          </label>

          <p
            id="login-status"
            class="theme-status <%= message ? (messageType === 'error' ? 'theme-status-error' : 'theme-status-success') : 'display-none' %>"><%= message || '' %></p>

          <button class="btn-google-blue" type="button" onClick="login()">Log in</button>
        </div>

        <div class="theme-links">
          <a class="text-link" href="/auth/forgot-password">Forgot your password?</a>
          <p>Don't have an account yet? <a class="text-link" href="/auth/signup">Create an account</a></p>
        </div>
      </div>
    </div>
  </section>
</main>

<footer>
  <%- include('./partials/footer'); %>
</footer>

</body>
</html>
<script>
  let loaderEl = document.getElementById("loader");
  let loginStatusEl = document.getElementById("login-status");

  function showLoader() {
    loaderEl.classList.remove('display-none');
  }

  function hideLoader() {
    loaderEl.classList.add('display-none');
  }

  function setLoginStatus(message, type = 'error') {
    loginStatusEl.innerText = message || '';
    loginStatusEl.classList.toggle('display-none', !message);
    loginStatusEl.classList.toggle('theme-status-error', Boolean(message) && type === 'error');
    loginStatusEl.classList.toggle('theme-status-success', Boolean(message) && type === 'success');
  }

  function submitOnEnter(event, submitAction) {
    if (event.key !== 'Enter') {
      return;
    }

    event.preventDefault();
    submitAction();
  }

  function login() {
    let email = document.getElementById('email').value;
    let password = document.getElementById('password').value;
    setLoginStatus('');

    let user = {
      email: email,
      password: password
    }

    showLoader();
    postData('/auth/local/login', user).then(response => {
      hideLoader();
      if (response && response.redirect) {
        window.location.href = response.redirect;
      }
    }).catch(error => {
      hideLoader();
      setLoginStatus(error, 'error');
    });
  }

  ['email', 'password'].forEach((fieldId) => {
    const inputEl = document.getElementById(fieldId);
    if (!inputEl) {
      return;
    }

    inputEl.addEventListener('keydown', (event) => submitOnEnter(event, login));
  });
</script>

<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('./partials/head'); %>
</head>
<body class="body-container">

<header>
  <%- include('./partials/header', {navItem: 'login'}); %>
</header>
  
<main>
  <div class="content-container">
    <div class="center-col-container">
      <div class="google-btn">
        <div class="google-icon-wrapper">
          <img class="google-icon" src="/images/google_logo.svg"/>
        </div>
        <p class="btn-text"><a href="/auth/google">Sign in with google</a></p>
      </div>
      <p>or</p>
      <div class="center-col-container">
        <div class="center-row-container">
          <input class="input-text" id="email" type="text" autocomplete="email" placeholder="Email">
        </div>
        <div class="center-row-container">
          <input class="input-text" id="password" type="password" autocomplete="password" placeholder="Password">
        </div>
        <p id="login-status" style="color: <%= messageType === 'error' ? 'red' : 'green' %>;"><%= message || '' %></p>
        <button class="btn-google-blue" onClick="login()">Login</button>
        <p><a href="/auth/forgot-password">Forgot your password?</a></p>
      </div>
      Don't have an account yet?<a href="/auth/signup">Click here to signup!</a>
    </div>
  </div>
</main>

<footer>
  <%- include('./partials/footer'); %>
</footer>

</body>
</html>
<script>
  
  let loaderEl = document.getElementById("loader");
  let loginStatusEl = document.getElementById("login-status");

  function showLoader() {
    loaderEl.classList.remove('display-none');
  }

  function hideLoader() {
    loaderEl.classList.add('display-none');
  }

  function submitOnEnter(event, submitAction) {
    if (event.key !== 'Enter') {
      return;
    }

    event.preventDefault();
    submitAction();
  }

  function login() {
    let email = document.getElementById('email').value;
    let password = document.getElementById('password').value;
    loginStatusEl.style.color = 'red';
    loginStatusEl.innerText = "";
    
    let user = {
      email: email,
      password: password
    }

    showLoader();
    postData('/auth/local/login', user).then(response => {
      hideLoader();
      if (response && response.redirect) {
        window.location.href = response.redirect;
      }
    }).catch(error => {
      hideLoader();
      loginStatusEl.innerText = error;
    });
  }

  ['email', 'password'].forEach((fieldId) => {
    const inputEl = document.getElementById(fieldId);
    if (!inputEl) {
      return;
    }

    inputEl.addEventListener('keydown', (event) => submitOnEnter(event, login));
  });
</script>

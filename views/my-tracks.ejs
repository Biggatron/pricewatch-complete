<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head'); %>
  <link rel="stylesheet" href="/css/dashboard.css?v=20260405-3" type="text/css">
  <link rel="stylesheet" href="/css/track.css?v=20260411-1" type="text/css">
</head>
<body class="body-container">

<%
  const priceFormatter = new Intl.NumberFormat('en-US');
  const dateFormatter = new Intl.DateTimeFormat('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric'
  });
  const formatPrice = (value) => {
    const numericValue = Number(value);
    return Number.isFinite(numericValue) ? priceFormatter.format(numericValue) : value;
  };
  const formatDate = (value) => {
    if (!value) {
      return 'N/A';
    }

    const parsedDate = new Date(value);
    return Number.isNaN(parsedDate.getTime()) ? 'N/A' : dateFormatter.format(parsedDate);
  };
  const getHost = (value) => {
    try {
      return new URL(value).hostname.replace(/^www\./, '');
    } catch (error) {
      return 'Tracked product';
    }
  };
  const getPriceToneClass = (track) => {
    if (Number(track.curr_price) < Number(track.orig_price)) {
      return 'dashboard-price-drop';
    }

    if (Number(track.curr_price) > Number(track.orig_price)) {
      return 'dashboard-price-rise';
    }

    return 'dashboard-price-flat';
  };
  const getStatus = (track) => {
    if (!track.active) {
      return {
        label: 'Inactive',
        toneClass: 'dashboard-status-muted'
      };
    }

    if (Number(track.curr_price) < Number(track.orig_price)) {
      return {
        label: 'Dropped',
        toneClass: 'dashboard-status-drop'
      };
    }

    if (Number(track.curr_price) > Number(track.orig_price)) {
      return {
        label: 'Higher',
        toneClass: 'dashboard-status-rise'
      };
    }

    return {
      label: 'Steady',
      toneClass: 'dashboard-status-flat'
    };
  };
  const trackList = Array.isArray(tracks) ? tracks : [];
  const activeTrackCount = trackList.filter((track) => track.active).length;
%>

<header>
  <%- include('partials/header', {navItem: 'my-tracks'}); %>
</header>

<main class="my-tracks-main">
  <section class="my-tracks-shell">
    <div class="dashboard-window my-tracks-window">
      <div class="dashboard-content">
        <div class="dashboard-header">
          <div>
            <h2>My tracked products</h2>
            <p class="dashboard-subtitle">Click any row to open the original product link, review the latest tracking details, and inspect the price history chart.</p>
          </div>
          <div class="dashboard-summary">
            <strong><%= activeTrackCount %></strong>
            <span>active tracks</span>
            <small><%= trackList.length %> total saved</small>
          </div>
        </div>

        <% if (trackList.length === 0) { %>
          <div class="dashboard-empty-state">
            <h3>No tracks yet</h3>
            <p>Add your first product and Pricewatcher will start monitoring it for changes.</p>
            <a class="btn" href="/">Start a new track</a>
          </div>
        <% } else { %>
          <div class="dashboard-table-wrap">
            <table class="dashboard-table my-tracks-table" id="track-table" aria-label="Tracked products">
              <thead>
                <tr>
                  <th>Product</th>
                  <th>Original</th>
                  <th>Current</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% trackList.forEach((track) => {
                  const status = getStatus(track);
                %>
                  <tr class="track-summary-row" data-track-toggle="<%= track.id %>" tabindex="0" role="button" aria-expanded="false">
                    <td data-label="Product">
                      <span class="dashboard-product-name"><%= track.product_name %></span>
                      <span class="dashboard-product-meta"><%= getHost(track.price_url) %> &middot; Added <%= formatDate(track.created_at) %></span>
                    </td>
                    <td class="dashboard-number-cell" data-label="Original"><%= formatPrice(track.orig_price) %></td>
                    <td class="dashboard-number-cell" data-label="Current">
                      <span class="dashboard-price-pill <%= getPriceToneClass(track) %>"><%= formatPrice(track.curr_price) %></span>
                    </td>
                    <td data-label="Status">
                      <span class="dashboard-status-pill <%= status.toneClass %>"><%= status.label %></span>
                    </td>
                  </tr>
                  <tr class="track-detail-row display-none" data-track-detail-row="<%= track.id %>">
                    <td colspan="4">
                      <div class="track-detail-card">
                        <div class="track-detail-meta">
                          <div class="track-detail-stat">
                            <span class="track-detail-stat-label">Tracking</span>
                            <strong><%= track.active ? 'Active' : 'Inactive' %></strong>
                          </div>
                          <div class="track-detail-stat">
                            <span class="track-detail-stat-label">Start date</span>
                            <strong><%= formatDate(track.created_at) %></strong>
                          </div>
                          <div class="track-detail-stat">
                            <span class="track-detail-stat-label">Last change</span>
                            <strong><%= formatDate(track.last_modified_at) %></strong>
                          </div>
                        </div>
                        <p class="track-detail-link-row">
                          <span class="track-detail-link-content">
                            <strong>Original link:</strong>
                            <a href="<%= track.price_url %>" target="_blank" rel="noreferrer"><%= track.price_url %></a>
                          </span>
                          <span class="track-detail-actions">
                            <% if (!track.active) { %>
                              <button
                                class="btn track-reactivate-btn"
                                type="button"
                                data-reactivate-button="<%= track.id %>"
                                onclick="reactivateTrack(<%= track.id %>, this)">Reactivate</button>
                            <% } %>
                            <button class="btn track-delete-btn" type="button" onclick="deleteTrack(<%= track.id %>)">Delete</button>
                          </span>
                        </p>
                        <%- include('partials/track-history-graph', { track }); %>
                      </div>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </section>
</main>

<div class="track-result-modal track-result-success display-none" id="track-reactivation-modal">
  <div class="track-result-modal-backdrop" onclick="closeReactivationPriceModal()"></div>
  <div class="track-result-modal-content">
    <button
      class="track-result-close-button"
      type="button"
      aria-label="Close popup"
      onclick="closeReactivationPriceModal()">X</button>
    <div class="track-result-message-wrap">
      <div class="track-result-badge" id="track-reactivation-badge">Reset track</div>
      <p class="track-result-message" id="track-reactivation-message"></p>
    </div>
    <div class="track-reset-form">
      <label class="theme-field track-reset-field" for="track-reactivation-price">
        <span class="theme-label">Current product price</span>
        <input
          class="theme-input track-reset-input"
          type="text"
          id="track-reactivation-price"
          placeholder="e.g. 2999"
          autocomplete="off"
          inputmode="decimal">
      </label>
      <div class="track-result-actions track-reset-actions">
        <button class="btn track-result-secondary-button" type="button" onclick="closeReactivationPriceModal()">Cancel</button>
        <button class="btn track-result-primary-button" type="button" id="track-reactivation-submit" onclick="submitReactivationPriceModal()">Reset track</button>
      </div>
    </div>
  </div>
</div>

<footer>
  <%- include('partials/footer'); %>
</footer>

</body>
</html>

<script>
  let loaderEl = document.getElementById("loader");
  const reactivationModalEl = document.getElementById("track-reactivation-modal");
  const reactivationMessageEl = document.getElementById("track-reactivation-message");
  const reactivationPriceInputEl = document.getElementById("track-reactivation-price");
  const reactivationSubmitButtonEl = document.getElementById("track-reactivation-submit");
  let pendingReactivationModalResolver = null;

  function showLoader() {
    loaderEl.classList.remove('display-none');
  }

  function hideLoader() {
    loaderEl.classList.add('display-none');
  }

  document.querySelectorAll('[data-track-toggle]').forEach((row) => {
    row.addEventListener('click', () => {
      toggleTrackDetail(row.dataset.trackToggle);
    });

    row.addEventListener('keydown', (event) => {
      if (event.key !== 'Enter' && event.key !== ' ') {
        return;
      }

      event.preventDefault();
      toggleTrackDetail(row.dataset.trackToggle);
    });
  });

  function toggleTrackDetail(trackId) {
    const summaryRow = document.querySelector(`[data-track-toggle="${trackId}"]`);
    const detailRow = document.querySelector(`[data-track-detail-row="${trackId}"]`);

    if (!summaryRow || !detailRow) {
      return;
    }

    const willExpand = detailRow.classList.contains('display-none');
    detailRow.classList.toggle('display-none', !willExpand);
    summaryRow.classList.toggle('track-summary-row-expanded', willExpand);
    summaryRow.setAttribute('aria-expanded', willExpand ? 'true' : 'false');
  }

  async function deleteTrack(trackId) {
    const confirmed = window.confirm('Are you sure you wish to delete this track?');
    if (!confirmed) {
      return;
    }

    showLoader();

    try {
      const response = await fetch(`/track/${trackId}`, {
        method: 'DELETE',
        headers: {
          'Content-Type': 'application/json; charset=UTF-8'
        }
      });
      const body = await response.json().catch(() => null);

      if (response.ok) {
        window.location.reload();
        return;
      }

      if (response.status === 401) {
        window.location.href = '/auth/login';
        return;
      }

      showToast(body && body.error ? body.error : 'Failed to delete track');
    } catch (error) {
      console.log(error);
      showToast('Failed to delete track');
    } finally {
      hideLoader();
    }
  }

  function setReactivateButtonState(buttonEl, isLoading, loadingLabel = 'Activating...') {
    if (!buttonEl) {
      return;
    }

    buttonEl.disabled = isLoading;
    buttonEl.innerText = isLoading ? loadingLabel : 'Reactivate';
  }

  function openReactivationPriceModal(message) {
    if (pendingReactivationModalResolver) {
      pendingReactivationModalResolver(null);
      pendingReactivationModalResolver = null;
    }

    reactivationMessageEl.innerText = message || 'Could not reactivate this track using the saved price location. Enter the current product price to reset it and try again.';
    reactivationPriceInputEl.value = '';
    reactivationModalEl.classList.remove('display-none');
    reactivationSubmitButtonEl.disabled = false;

    window.setTimeout(() => {
      reactivationPriceInputEl.focus();
    }, 0);

    return new Promise((resolve) => {
      pendingReactivationModalResolver = resolve;
    });
  }

  function closeReactivationPriceModal(value = null) {
    reactivationModalEl.classList.add('display-none');
    reactivationSubmitButtonEl.disabled = false;

    if (pendingReactivationModalResolver) {
      const resolve = pendingReactivationModalResolver;
      pendingReactivationModalResolver = null;
      resolve(value);
    }
  }

  function submitReactivationPriceModal() {
    const trimmedValue = reactivationPriceInputEl.value.trim();
    if (!trimmedValue) {
      showToast('Enter the current product price');
      reactivationPriceInputEl.focus();
      return;
    }

    closeReactivationPriceModal(trimmedValue);
  }

  async function resetTrackReactivation(trackId, buttonEl, price) {
    setReactivateButtonState(buttonEl, true, 'Resetting...');

    const response = await fetch(`/track/${trackId}/reactivate/reset`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json; charset=UTF-8'
      },
      body: JSON.stringify({ price })
    });
    const body = await response.json().catch(() => null);

    if (response.ok) {
      showToast(body && body.message ? body.message : 'Track reactivated');
      window.location.reload();
      return { completed: true };
    }

    if (response.status === 401) {
      window.location.href = '/auth/login';
      return { completed: true };
    }

    showToast(body && body.error ? body.error : 'Failed to reset track');
    return { completed: false };
  }

  async function reactivateTrack(trackId, buttonEl) {
    let shouldResetButton = true;
    setReactivateButtonState(buttonEl, true, 'Activating...');

    try {
      const response = await fetch(`/track/${trackId}/reactivate`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json; charset=UTF-8'
        }
      });
      const body = await response.json().catch(() => null);

      if (response.ok) {
        shouldResetButton = false;
        showToast(body && body.message ? body.message : 'Track reactivated');
        window.location.reload();
        return;
      }

      if (response.status === 401) {
        shouldResetButton = false;
        window.location.href = '/auth/login';
        return;
      }

      if (response.status === 422 && body && body.allowPriceReset) {
        const price = await openReactivationPriceModal(body.error);
        if (!price) {
          return;
        }

        const resetResult = await resetTrackReactivation(trackId, buttonEl, price);
        if (resetResult.completed) {
          shouldResetButton = false;
        }
        return;
      }

      showToast(body && body.error ? body.error : 'Failed to reactivate track');
    } catch (error) {
      console.log(error);
      showToast('Failed to reactivate track');
    } finally {
      if (shouldResetButton) {
        setReactivateButtonState(buttonEl, false);
      }
    }
  }

  reactivationPriceInputEl.addEventListener('keydown', (event) => {
    if (event.key === 'Enter') {
      event.preventDefault();
      submitReactivationPriceModal();
      return;
    }

    if (event.key === 'Escape') {
      event.preventDefault();
      closeReactivationPriceModal();
    }
  });
</script>

<script>
  let loaderEl = document.getElementById("loader");
  const urlInputEl = document.getElementById("url");
  const priceInputEl = document.getElementById("price");
  const previewContainerEl = document.getElementById("previewContainer");
  const previewStatusEl = document.getElementById("previewStatus");
  const productIframeEl = document.getElementById("productIframe");
  const productPreviewImageEl = document.getElementById("productPreviewImage");
  const productPreviewImageLinkEl = document.getElementById("productPreviewImageLink");
  const trackResultModalEl = document.getElementById("track-result-modal");
  const trackResultBadgeEl = document.getElementById("track-result-badge");
  const trackResultMessageEl = document.getElementById("track-result-message");
  const trackResultActionsEl = document.getElementById("track-result-actions");
  const trackPriceButtonEl = document.getElementById("track-price-button");
  let previewDebounceTimer = null;
  let previewAbortController = null;
  let previewRequestId = 0;
  let lastAutofilledPrice = '';
  let lastExistingTrackPopupUrl = '';
  let isSubmittingTrack = false;

  let user;
  user = '<%- JSON.stringify(user) %>';
  if (user) {
    user = JSON.parse(user);
  }
  
  //import fetch from 'node-fetch';
  console.log('Coockie incomming!')
  console.log(document.cookie);


  /* Event listener */
  urlInputEl.addEventListener('input', queuePreviewLoad);
  priceInputEl.addEventListener('input', () => {
    if (priceInputEl.value !== lastAutofilledPrice) {
      lastAutofilledPrice = '';
    }
  });

  /* Function */
  function queuePreviewLoad() {
    const url = this.value.trim();

    clearTimeout(previewDebounceTimer);
    if (previewAbortController) {
      previewAbortController.abort();
      previewAbortController = null;
    }

    if (!url) {
      clearPreview();
      return;
    }

    previewDebounceTimer = setTimeout(() => {
      loadPreview(url);
    }, 250);
  }
  
  function showLoader() {
    loaderEl.classList.remove('display-none');
  }

  function hideLoader() {
    loaderEl.classList.add('display-none');
  }

  function submitOnEnter(event, submitAction) {
    if (event.key !== 'Enter') {
      return;
    }

    event.preventDefault();
    submitAction();
  }

  function trackPrice() {
    if (isSubmittingTrack) {
      return;
    }

    var track = {
      email: user ? user.email : document.getElementById('email').value,
      url: document.getElementById('url').value,
      price: document.getElementById('price').value
    }
    console.log(track);
    postTrack(track);
  }

  function showTrackResultModal(message, options = {}) {
    const isSuccess = Boolean(options.isSuccess);
    const showActions = Boolean(options.showActions);
    const showBadge = options.showBadge !== false;

    trackResultBadgeEl.innerText = isSuccess ? 'Success' : 'Not added';
    trackResultBadgeEl.classList.toggle('display-none', !showBadge);
    trackResultModalEl.classList.toggle('track-result-success', isSuccess);
    trackResultModalEl.classList.toggle('track-result-failure', !isSuccess);
    trackResultMessageEl.innerText = message;
    trackResultActionsEl.classList.toggle('display-none', !showActions);
    trackResultModalEl.classList.remove('display-none');
  }

  function closeTrackResultModal() {
    trackResultModalEl.classList.add('display-none');
  }

  function prepareAnotherTrack() {
    closeTrackResultModal();
    document.getElementById('url').value = '';
    document.getElementById('price').value = '';
    lastAutofilledPrice = '';
    lastExistingTrackPopupUrl = '';
    clearPreview();
    document.getElementById('url').focus();
  }

  function setTrackSubmissionState(isSubmitting) {
    isSubmittingTrack = isSubmitting;
    trackPriceButtonEl.disabled = isSubmitting;
    trackPriceButtonEl.innerText = isSubmitting ? 'Tracking...' : 'Track Price';
  }

  async function postTrack(track) {
    if (isSubmittingTrack) {
      return;
    }

    setTrackSubmissionState(true);
    console.log('About to fetch')
    showLoader();
    try {
      let response = await fetch("/track",{
        // method changes
        method: 'POST',
        body: JSON.stringify(track),
        headers: {
            "Content-type": "application/json; charset=UTF-8"
        }
      });
      hideLoader();
      const responseBody = await response.json().catch(() => null);
      if (response.status === 201) {  
        showTrackResultModal(
          responseBody && responseBody.message ? responseBody.message : 'Track added successfully',
          { isSuccess: true, showActions: true }
        );
      } else if (response.status === 200) {
        showTrackResultModal(
          responseBody && responseBody.message ? responseBody.message : 'Price not found on page',
          {
            isSuccess: responseBody && responseBody.code === 'TRACK_EXISTS',
            showActions: responseBody && responseBody.code === 'TRACK_EXISTS',
            showBadge: !(responseBody && responseBody.code === 'TRACK_EXISTS')
          }
        );
      } else if (response.status === 400) {
        showTrackResultModal(
          responseBody && responseBody.error ? responseBody.error : 'Invalid track input'
        );
      } else if (response.status === 401) {
        console.log('status 401')
        window.location.href = "/pages/login";
      } else if (response.status === 206) {
        showTrackResultModal(
          responseBody && responseBody.message ? responseBody.message : 'Track partially saved'
        );
      } else {
        showTrackResultModal('Something went wrong');
      }
    } catch (err) {
      hideLoader();
      showTrackResultModal('Something went wrong');
      console.log(err)
    } finally {
      hideLoader();
      setTrackSubmissionState(false);
    }
  }

  ['email', 'url', 'price'].forEach((fieldId) => {
    const inputEl = document.getElementById(fieldId);
    if (!inputEl) {
      return;
    }

    inputEl.addEventListener('keydown', (event) => submitOnEnter(event, trackPrice));
  });

  async function lookupExistingTrack(url) {
    try {
      const response = await fetch('/track/lookup', {
        method: 'POST',
        body: JSON.stringify({ url }),
        headers: {
          "Content-type": "application/json; charset=UTF-8"
        }
      });

      const body = await response.json().catch(() => null);
      if (response.status === 401) {
        window.location.href = '/auth/login';
        return { blocked: true };
      }

      if (!response.ok) {
        return { blocked: false };
      }

      return body || {};
    } catch (error) {
      console.log(error);
      return { blocked: false };
    }
  }

  function maybeAutofillPrice(currentPrice) {
    if (currentPrice == null) {
      return;
    }

    const normalizedPrice = String(currentPrice);
    if (priceInputEl.value && priceInputEl.value !== lastAutofilledPrice) {
      return;
    }

    priceInputEl.value = normalizedPrice;
    lastAutofilledPrice = normalizedPrice;
  }

  async function loadPreview(url) {
    if (!isValidHttpUrl(url)) {
      showPreviewMessage('Enter a valid http(s) URL to load a preview.');
      return;
    }

    const lookupResult = await lookupExistingTrack(url);
    if (lookupResult && lookupResult.blocked) {
      return;
    }

    if (lookupResult && lookupResult.sameUserTrack) {
      clearPreview();
      if (lastExistingTrackPopupUrl !== url || trackResultModalEl.classList.contains('display-none')) {
        showTrackResultModal(
          lookupResult.message || "You're already tracking this product",
          { showActions: true, showBadge: false }
        );
      }
      lastExistingTrackPopupUrl = url;
      return;
    }

    lastExistingTrackPopupUrl = '';

    if (lookupResult && lookupResult.otherUserTrack) {
      maybeAutofillPrice(lookupResult.currentPrice);
    }

    const requestId = ++previewRequestId;
    previewAbortController = new AbortController();
    showPreviewMessage('Loading preview...');

    try {
      const response = await fetch('/track/preview', {
        method: 'POST',
        body: JSON.stringify({ url }),
        headers: {
          "Content-type": "application/json; charset=UTF-8"
        },
        signal: previewAbortController.signal
      });

      const body = await response.json().catch(() => null);
      if (requestId !== previewRequestId) {
        return;
      }

      if (!response.ok) {
        showPreviewMessage(body && body.error ? body.error : 'Failed to load preview.');
        return;
      }

      if (body && body.mode === 'screenshot' && body.imageUrl) {
        showScreenshotPreview(body.imageUrl, body.url || url);
      } else {
        showIframePreview(body && body.url ? body.url : url);
      }
    } catch (error) {
      if (error.name === 'AbortError') {
        return;
      }

      console.log(error);
      showPreviewMessage('Failed to load preview.');
    } finally {
      if (requestId === previewRequestId) {
        previewAbortController = null;
      }
    }
  }

  function showIframePreview(url) {
    previewContainerEl.classList.remove('display-none');
    productPreviewImageLinkEl.classList.add('display-none');
    productPreviewImageEl.removeAttribute('src');
    productIframeEl.classList.remove('display-none');
    productIframeEl.src = url;
    hidePreviewMessage();
  }

  function showScreenshotPreview(imageUrl, sourceUrl) {
    previewContainerEl.classList.remove('display-none');
    productIframeEl.classList.add('display-none');
    productIframeEl.src = '';
    productPreviewImageLinkEl.classList.remove('display-none');
    productPreviewImageLinkEl.href = sourceUrl;
    productPreviewImageEl.src = `${imageUrl}${imageUrl.includes('?') ? '&' : '?'}t=${Date.now()}`;
    hidePreviewMessage();
  }

  function showPreviewMessage(message) {
    previewContainerEl.classList.remove('display-none');
    productIframeEl.classList.add('display-none');
    productIframeEl.src = '';
    productPreviewImageLinkEl.classList.add('display-none');
    productPreviewImageEl.removeAttribute('src');
    previewStatusEl.classList.remove('display-none');
    previewStatusEl.textContent = message;
  }

  function clearPreview() {
    previewContainerEl.classList.add('display-none');
    productIframeEl.classList.add('display-none');
    productIframeEl.src = '';
    productPreviewImageLinkEl.classList.add('display-none');
    productPreviewImageEl.removeAttribute('src');
    previewStatusEl.classList.remove('display-none');
    previewStatusEl.textContent = 'Enter a URL to load a preview.';
  }

  function hidePreviewMessage() {
    previewStatusEl.textContent = '';
    previewStatusEl.classList.add('display-none');
  }

  function isValidHttpUrl(value) {
    try {
      const parsedUrl = new URL(value);
      return parsedUrl.protocol === 'http:' || parsedUrl.protocol === 'https:';
    } catch (error) {
      return false;
    }
  }
</script>

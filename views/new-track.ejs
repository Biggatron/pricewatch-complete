<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head'); %>
  <link rel="stylesheet" href="/css/track.css?v=20260412-1" type="text/css">
</head>
<body class="body-container">

<header>
  <%- include('partials/header', {navItem: 'new-track'}); %>
</header>

<main class="themed-main new-track-main">
  <section class="page-shell page-shell-wide">
    <div class="page-card-panel track-builder-form-panel">
      <div class="track-builder-form track-builder-form-url-only" id="trackBuilderForm">
        <% if (!user) { %>
          <label class="theme-field" for="email">
            <span class="theme-label">Email</span>
            <input class="theme-input" type="email" id="email" name="contact_email" value="" placeholder="example@example.com" autocomplete="section-new-track email" autocapitalize="off" spellcheck="false">
          </label>
        <% }; %>

        <label class="theme-field" for="url">
          <span class="theme-label">Product URL</span>
          <div class="track-url-input-row">
            <input class="theme-input" type="url" name="track_url" id="url" value="" placeholder="https://example.com/product" autocomplete="off" autocapitalize="off" spellcheck="false">
            <button
              class="track-clipboard-btn"
              id="paste-url-button"
              type="button"
              aria-label="Paste URL from clipboard"
              title="Paste URL from clipboard"
              onclick="pasteUrlFromClipboard()">
              <img class="track-clipboard-icon" src="/images/paste-icon.png" alt="" aria-hidden="true">
            </button>
          </div>
        </label>

        <label class="theme-field display-none" id="priceFieldWrap" for="price">
          <span class="theme-label track-price-label">
            <span>Product price</span>
            <span class="track-help-wrap">
              <button
                class="track-help-trigger"
                type="button"
                aria-label="What is product price?"
                aria-describedby="price-help-tooltip">?</button>
              <span class="track-help-tooltip" id="price-help-tooltip" role="tooltip">Current product price to help the system locate the correct price to track</span>
            </span>
          </span>
          <input class="theme-input" type="text" name="target_price" id="price" placeholder="e.g. 2999" autocomplete="off" inputmode="decimal">
        </label>

        <button class="btn track-submit-btn display-none" id="track-price-button" type="button" onClick="trackPrice()">Track</button>
      </div>
    </div>

    <div id="previewContainer" class="preview-container display-none">
      <p id="previewStatus" class="preview-status">Enter a URL to load a preview.</p>
      <iframe id="productIframe" class="display-none" title="Price Selection" width="100%" height="auto" src=""></iframe>
      <a id="productPreviewImageLink" class="preview-image-link display-none" href="" target="_blank" rel="noreferrer">
        <img id="productPreviewImage" class="preview-image" alt="Product preview screenshot">
      </a>
    </div>
  </section>
</main>

<div class="track-result-modal display-none" id="track-result-modal">
  <div class="track-result-modal-backdrop" onclick="closeTrackResultModal()"></div>
  <div class="track-result-modal-content">
    <div class="track-result-loading-overlay display-none" id="track-result-loading-overlay" aria-hidden="true">
      <div class="track-result-loading-spinner" aria-hidden="true"></div>
    </div>
    <button class="track-result-close-button" type="button" aria-label="Close popup" onclick="closeTrackResultModal()">X</button>
    <div class="track-result-message-wrap">
      <div class="track-result-badge" id="track-result-badge">Success</div>
      <p class="track-result-message" id="track-result-message"></p>
    </div>
    <div class="track-result-actions display-none" id="track-result-decision-actions">
      <button class="btn track-result-secondary-button" id="track-result-secondary-action" type="button">Enter price manually</button>
      <button class="btn track-result-primary-button" id="track-result-primary-action" type="button">Looks good</button>
    </div>
    <div class="track-result-actions display-none" id="track-result-actions">
      <button class="btn track-result-secondary-button" type="button" onclick="prepareAnotherTrack()">Add another track</button>
      <a class="btn track-result-primary-button" href="/tracklist">Go to My tracks</a>
    </div>
  </div>
</div>

<footer>
  <%- include('partials/footer'); %>
</footer>

</body>
</html>

<script>
  let loaderEl = document.getElementById("loader");
  const trackBuilderFormEl = document.getElementById("trackBuilderForm");
  const urlInputEl = document.getElementById("url");
  const priceInputEl = document.getElementById("price");
  const priceFieldWrapEl = document.getElementById("priceFieldWrap");
  const previewContainerEl = document.getElementById("previewContainer");
  const previewStatusEl = document.getElementById("previewStatus");
  const productIframeEl = document.getElementById("productIframe");
  const productPreviewImageEl = document.getElementById("productPreviewImage");
  const productPreviewImageLinkEl = document.getElementById("productPreviewImageLink");
  const trackResultModalEl = document.getElementById("track-result-modal");
  const trackResultBadgeEl = document.getElementById("track-result-badge");
  const trackResultMessageEl = document.getElementById("track-result-message");
  const trackResultDecisionActionsEl = document.getElementById("track-result-decision-actions");
  const trackResultLoadingOverlayEl = document.getElementById("track-result-loading-overlay");
  const trackResultPrimaryActionEl = document.getElementById("track-result-primary-action");
  const trackResultSecondaryActionEl = document.getElementById("track-result-secondary-action");
  const trackResultActionsEl = document.getElementById("track-result-actions");
  const trackPriceButtonEl = document.getElementById("track-price-button");
  const pasteUrlButtonEl = document.getElementById("paste-url-button");
  let previewDebounceTimer = null;
  let previewAbortController = null;
  let previewRequestId = 0;
  let lastExistingTrackPopupUrl = '';
  let isSubmittingTrack = false;
  let isTrackResultSaving = false;
  let detectionRequestId = 0;
  let pendingDetectedTrack = null;

  let user;
  user = '<%- JSON.stringify(user) %>';
  if (user) {
    user = JSON.parse(user);
  }

  urlInputEl.addEventListener('input', queuePreviewLoad);

  function queuePreviewLoad() {
    const url = this.value.trim();

    clearTimeout(previewDebounceTimer);
    if (previewAbortController) {
      previewAbortController.abort();
      previewAbortController = null;
    }

    if (!url) {
      pendingDetectedTrack = null;
      hideManualPriceEntry();
      clearPreview();
      return;
    }

    previewDebounceTimer = setTimeout(() => {
      loadPreview(url);
      detectTrackCandidate(url);
    }, 250);
  }

  function showLoader() {
    loaderEl.classList.remove('display-none');
  }

  function hideLoader() {
    loaderEl.classList.add('display-none');
  }

  function submitOnEnter(event, submitAction) {
    if (event.key !== 'Enter') {
      return;
    }

    event.preventDefault();
    submitAction();
  }

  function trackPrice() {
    if (isSubmittingTrack) {
      return;
    }

    if (!priceInputEl.value.trim()) {
      showTrackResultModal('Enter the current product price to continue.');
      return;
    }

    var track = {
      email: user ? user.email : document.getElementById('email').value,
      url: document.getElementById('url').value,
      price: document.getElementById('price').value
    }
    postTrack(track);
  }

  function showTrackResultModal(message, options = {}) {
    const isSuccess = Boolean(options.isSuccess);
    const showActions = Boolean(options.showActions);
    const showDecisionActions = Boolean(options.showDecisionActions);
    const showBadge = options.showBadge !== false;

    trackResultBadgeEl.innerText = options.badgeText || (isSuccess ? 'Success' : 'Not added');
    trackResultBadgeEl.classList.toggle('display-none', !showBadge);
    trackResultModalEl.classList.toggle('track-result-success', isSuccess);
    trackResultModalEl.classList.toggle('track-result-failure', !isSuccess);
    trackResultMessageEl.innerText = message;
    trackResultDecisionActionsEl.classList.toggle('display-none', !showDecisionActions);
    trackResultActionsEl.classList.toggle('display-none', !showActions);
    trackResultModalEl.classList.remove('display-none');
  }

  function closeTrackResultModal() {
    if (isTrackResultSaving) {
      return;
    }

    resetTrackResultDecisionActions();
    trackResultModalEl.classList.add('display-none');
  }

  function prepareAnotherTrack() {
    closeTrackResultModal();
    document.getElementById('url').value = '';
    document.getElementById('price').value = '';
    lastExistingTrackPopupUrl = '';
    pendingDetectedTrack = null;
    hideManualPriceEntry();
    clearPreview();
    document.getElementById('url').focus();
  }

  function resetTrackResultDecisionActions() {
    isTrackResultSaving = false;
    trackResultPrimaryActionEl.onclick = null;
    trackResultSecondaryActionEl.onclick = null;
    trackResultPrimaryActionEl.textContent = 'Looks good';
    trackResultSecondaryActionEl.textContent = 'Enter price manually';
    trackResultPrimaryActionEl.disabled = false;
    trackResultSecondaryActionEl.disabled = false;
    trackResultLoadingOverlayEl.classList.add('display-none');
    trackResultDecisionActionsEl.classList.add('display-none');
  }

  function setTrackResultSavingState(isSaving) {
    isTrackResultSaving = isSaving;
    trackResultPrimaryActionEl.disabled = isSaving;
    trackResultSecondaryActionEl.disabled = isSaving;
    trackResultPrimaryActionEl.textContent = isSaving ? 'Saving track...' : 'Looks good';
    trackResultSecondaryActionEl.textContent = 'Enter price manually';
    trackResultLoadingOverlayEl.classList.toggle('display-none', !isSaving);
  }

  function hideManualPriceEntry() {
    priceFieldWrapEl.classList.add('display-none');
    trackPriceButtonEl.classList.add('display-none');
    trackBuilderFormEl.classList.add('track-builder-form-url-only');
    priceInputEl.value = '';
  }

  function showManualPriceEntry() {
    pendingDetectedTrack = null;
    resetTrackResultDecisionActions();
    priceFieldWrapEl.classList.remove('display-none');
    trackPriceButtonEl.classList.remove('display-none');
    trackBuilderFormEl.classList.remove('track-builder-form-url-only');
    closeTrackResultModal();
    priceInputEl.focus();
  }

  function showDetectedTrackConfirmation(url, details = {}) {
    pendingDetectedTrack = {
      url,
      price: String(details.currentPrice == null ? '' : details.currentPrice),
      priceDisplay: String(details.currentPriceDisplay == null ? (details.currentPrice == null ? '' : details.currentPrice) : details.currentPriceDisplay),
      productName: details.productName || 'this product'
    };

    trackResultPrimaryActionEl.textContent = 'Looks good';
    trackResultSecondaryActionEl.textContent = 'Enter price manually';
    trackResultPrimaryActionEl.onclick = confirmDetectedTrack;
    trackResultSecondaryActionEl.onclick = showManualPriceEntry;

    const productName = pendingDetectedTrack.productName;
    const price = pendingDetectedTrack.priceDisplay || pendingDetectedTrack.price;
    showTrackResultModal(
      `${productName} at ${price} \nDoes this track look right?`,
      { isSuccess: true, showBadge: true, showDecisionActions: true, badgeText: 'Match found' }
    );
  }

  function confirmDetectedTrack() {
    if (!pendingDetectedTrack) {
      showManualPriceEntry();
      return;
    }

    postTrack({
      email: user ? user.email : document.getElementById('email').value,
      url: pendingDetectedTrack.url,
      price: pendingDetectedTrack.price
    }, {
      keepModalOpenWhileSubmitting: true
    });
  }

  function setTrackSubmissionState(isSubmitting) {
    isSubmittingTrack = isSubmitting;
    trackPriceButtonEl.disabled = isSubmitting;
    trackPriceButtonEl.innerText = isSubmitting ? 'Tracking...' : 'Track price';
  }

  function setPasteUrlButtonState(isLoading, label) {
    if (!pasteUrlButtonEl) {
      return;
    }

    pasteUrlButtonEl.disabled = isLoading;
    const buttonLabel = label || (isLoading ? 'Pasting URL from clipboard' : 'Paste URL from clipboard');
    pasteUrlButtonEl.setAttribute('aria-label', buttonLabel);
    pasteUrlButtonEl.setAttribute('title', buttonLabel);
  }

  async function pasteUrlFromClipboard() {
    if (!navigator.clipboard || typeof navigator.clipboard.readText !== 'function') {
      showTrackResultModal('Clipboard access is not available in this browser.');
      return;
    }

    setPasteUrlButtonState(true, 'Pasting...');

    try {
      const clipboardText = (await navigator.clipboard.readText()).trim();

      if (!clipboardText) {
        showTrackResultModal('Clipboard is empty.');
        return;
      }

      urlInputEl.value = clipboardText;
      queuePreviewLoad.call(urlInputEl);
      urlInputEl.focus();
      urlInputEl.select();
    } catch (error) {
      console.log(error);
      showTrackResultModal('Could not read the clipboard. Please allow clipboard access and try again.');
    } finally {
      setPasteUrlButtonState(false, 'Paste');
    }
  }

  async function postTrack(track, options = {}) {
    if (isSubmittingTrack) {
      return;
    }

    const keepModalOpenWhileSubmitting = Boolean(options.keepModalOpenWhileSubmitting);
    setTrackSubmissionState(true);
    pendingDetectedTrack = null;
    if (keepModalOpenWhileSubmitting) {
      setTrackResultSavingState(true);
      showLoader();
    } else {
      showLoader();
    }
    try {
      let response = await fetch("/track",{
        method: 'POST',
        body: JSON.stringify(track),
        headers: {
            "Content-type": "application/json; charset=UTF-8"
        }
      });

      if (keepModalOpenWhileSubmitting) {
        setTrackResultSavingState(false);
      }

      hideLoader();
      const responseBody = await response.json().catch(() => null);
      if (response.status === 201) {
        showTrackResultModal(
          responseBody && responseBody.message ? responseBody.message : 'Track added successfully',
          { isSuccess: true, showActions: true }
        );
      } else if (response.status === 200) {
        showTrackResultModal(
          responseBody && responseBody.message ? responseBody.message : 'Price not found on page',
          {
            isSuccess: responseBody && responseBody.code === 'TRACK_EXISTS',
            showActions: responseBody && responseBody.code === 'TRACK_EXISTS',
            showBadge: !(responseBody && responseBody.code === 'TRACK_EXISTS')
          }
        );
      } else if (response.status === 400) {
        showTrackResultModal(
          responseBody && responseBody.error ? responseBody.error : 'Invalid track input'
        );
      } else if (response.status === 401) {
        window.location.href = "/auth/login";
      } else if (response.status === 206) {
        showTrackResultModal(
          responseBody && responseBody.message ? responseBody.message : 'Track partially saved'
        );
      } else {
        showTrackResultModal('Something went wrong');
      }
    } catch (err) {
      if (keepModalOpenWhileSubmitting) {
        setTrackResultSavingState(false);
      }

      hideLoader();
      showTrackResultModal('Something went wrong');
      console.log(err)
    } finally {
      hideLoader();
      setTrackSubmissionState(false);
    }
  }

  ['email', 'price'].forEach((fieldId) => {
    const inputEl = document.getElementById(fieldId);
    if (!inputEl) {
      return;
    }

    inputEl.addEventListener('keydown', (event) => submitOnEnter(event, trackPrice));
  });

  async function detectTrackCandidate(url) {
    const requestId = ++detectionRequestId;

    if (!isValidHttpUrl(url)) {
      hideManualPriceEntry();
      return;
    }

    try {
      const response = await fetch('/track/detect', {
        method: 'POST',
        body: JSON.stringify({ url }),
        headers: {
          "Content-type": "application/json; charset=UTF-8"
        }
      });

      const body = await response.json().catch(() => null);
      if (requestId !== detectionRequestId) {
        return;
      }

      if (response.status === 401) {
        window.location.href = '/auth/login';
        return;
      }

      if (!response.ok) {
        showManualPriceEntry();
        return;
      }

      if (body && body.sameUserTrack) {
        hideManualPriceEntry();
        pendingDetectedTrack = null;
        if (lastExistingTrackPopupUrl !== url || trackResultModalEl.classList.contains('display-none')) {
          showTrackResultModal(
            body.message || "You're already tracking this product",
            { showActions: true, showBadge: false }
          );
        }
        lastExistingTrackPopupUrl = url;
        return;
      }

      lastExistingTrackPopupUrl = '';

      if (body && body.selectorFound && body.currentPrice != null) {
        hideManualPriceEntry();
        showDetectedTrackConfirmation(url, {
          currentPrice: body.currentPrice,
          currentPriceDisplay: body.currentPriceDisplay,
          productName: body.productName || 'this product'
        });
        return;
      }

      showManualPriceEntry();
    } catch (error) {
      console.log(error);
      if (requestId === detectionRequestId) {
        showManualPriceEntry();
      }
    }
  }

  async function loadPreview(url) {
    if (!isValidHttpUrl(url)) {
      showPreviewMessage('Enter a valid http(s) URL to load a preview.');
      return;
    }

    const requestId = ++previewRequestId;
    previewAbortController = new AbortController();
    showPreviewMessage('Loading preview...');

    try {
      const response = await fetch('/track/preview', {
        method: 'POST',
        body: JSON.stringify({ url }),
        headers: {
          "Content-type": "application/json; charset=UTF-8"
        },
        signal: previewAbortController.signal
      });

      const body = await response.json().catch(() => null);
      if (requestId !== previewRequestId) {
        return;
      }

      if (!response.ok) {
        showPreviewMessage(body && body.error ? body.error : 'Failed to load preview.');
        return;
      }

      if (body && body.mode === 'screenshot' && body.imageUrl) {
        showScreenshotPreview(body.imageUrl, body.url || url);
      } else {
        showIframePreview(body && body.url ? body.url : url);
      }
    } catch (error) {
      if (error.name === 'AbortError') {
        return;
      }

      console.log(error);
      showPreviewMessage('Failed to load preview.');
    } finally {
      if (requestId === previewRequestId) {
        previewAbortController = null;
      }
    }
  }

  function showIframePreview(url) {
    previewContainerEl.classList.remove('display-none');
    productPreviewImageLinkEl.classList.add('display-none');
    productPreviewImageEl.removeAttribute('src');
    productIframeEl.classList.remove('display-none');
    productIframeEl.src = url;
    hidePreviewMessage();
  }

  function showScreenshotPreview(imageUrl, sourceUrl) {
    previewContainerEl.classList.remove('display-none');
    productIframeEl.classList.add('display-none');
    productIframeEl.src = '';
    productPreviewImageLinkEl.classList.remove('display-none');
    productPreviewImageLinkEl.href = sourceUrl;
    productPreviewImageEl.src = `${imageUrl}${imageUrl.includes('?') ? '&' : '?'}t=${Date.now()}`;
    hidePreviewMessage();
  }

  function showPreviewMessage(message) {
    previewContainerEl.classList.remove('display-none');
    productIframeEl.classList.add('display-none');
    productIframeEl.src = '';
    productPreviewImageLinkEl.classList.add('display-none');
    productPreviewImageEl.removeAttribute('src');
    previewStatusEl.classList.remove('display-none');
    previewStatusEl.textContent = message;
  }

  function clearPreview() {
    previewContainerEl.classList.add('display-none');
    productIframeEl.classList.add('display-none');
    productIframeEl.src = '';
    productPreviewImageLinkEl.classList.add('display-none');
    productPreviewImageEl.removeAttribute('src');
    previewStatusEl.classList.remove('display-none');
    previewStatusEl.textContent = 'Enter a URL to load a preview.';
  }

  function hidePreviewMessage() {
    previewStatusEl.textContent = '';
    previewStatusEl.classList.add('display-none');
  }

  function isValidHttpUrl(value) {
    try {
      const parsedUrl = new URL(value);
      return parsedUrl.protocol === 'http:' || parsedUrl.protocol === 'https:';
    } catch (error) {
      return false;
    }
  }
</script>

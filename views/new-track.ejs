<!DOCTYPE html> 
<html lang="en">
<head>
  <%- include('partials/head'); %>
  <link rel="stylesheet" href="/css/track.css?v=20260403-1" type="text/css">
</head>
<body class="body-container">

<header>
  <%- include('partials/header', {navItem: 'new-track'}); %>
</header>

<main>
  <div class="container">
    <% if (!user) { %>
    <div class="form-group">
      <label for="email">Email:</label>
      <input type="email" id="email" name="contact_email" value="" placeholder="example@example.com" autocomplete="section-new-track email" autocapitalize="off" spellcheck="false">
    </div>
    <% }; %>
    <div class="form-group">
      <label for="url">URL:</label>
      <input type="url" name="track_url" id="url" value="" placeholder="https://example.com" autocomplete="off" autocapitalize="off" spellcheck="false">
    </div>
    <div class="form-group">
      <label for="price">Price:</label>
      <input type="text" name="target_price" id="price" placeholder="e.g. 2999" autocomplete="off" inputmode="decimal">
    </div>
    <button class="btn" id="track-price-button" type="button" onClick="trackPrice()">Track Price</button>
  </div>
  <div id="previewContainer" class="preview-container display-none">
    <p id="previewStatus" class="preview-status">Enter a URL to load a preview.</p>
    <iframe id="productIframe" class="display-none" title="Price Selection" width="100%" height="auto" src=""></iframe>
    <a id="productPreviewImageLink" class="preview-image-link display-none" href="" target="_blank" rel="noreferrer">
      <img id="productPreviewImage" class="preview-image" alt="Product preview screenshot">
    </a>
  </div>
</main>

<div class="track-result-modal display-none" id="track-result-modal">
  <div class="track-result-modal-backdrop" onclick="closeTrackResultModal()"></div>
  <div class="track-result-modal-content">
    <button class="track-result-close-button" type="button" aria-label="Close popup" onclick="closeTrackResultModal()">X</button>
    <div class="track-result-message-wrap">
      <div class="track-result-badge" id="track-result-badge">Success</div>
      <p class="track-result-message" id="track-result-message"></p>
    </div>
    <div class="track-result-actions display-none" id="track-result-actions">
      <button class="btn track-result-secondary-button" type="button" onclick="prepareAnotherTrack()">Add another track</button>
      <a class="btn track-result-primary-button" href="/tracklist">Go to My tracks</a>
    </div>
  </div>
</div>



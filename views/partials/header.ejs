<nav class="top-nav">
  <% const showAdminLink = typeof isAdmin !== 'undefined' ? isAdmin : false; %>
  <% const navLinks = [
    { key: 'new-track', href: user ? '/' : '/auth/login', label: 'New track' },
    { key: 'my-tracks', href: '/tracklist', label: 'My tracks' }
  ]; %>
  <% if (showAdminLink) { navLinks.push({ key: 'admin', href: '/admin', label: 'Admin' }); } %>

  <input id="menu-toggle" class="menu-toggle" type="checkbox" />

  <div class="top-nav-primary">
    <div class="top-nav-start">
      <label class="menu-button-container" for="menu-toggle" aria-label="Toggle navigation">
        <span class="menu-button"></span>
      </label>

      <ul class="menu menu-desktop">
        <% navLinks.forEach((link) => { %>
          <li>
            <a class="navbar-item <%= navItem === link.key ? 'navbar-highlight' : 'nav-link' %>" href="<%= link.href %>"><%= link.label %></a>
          </li>
        <% }); %>
      </ul>
    </div>

    <div class="navbar-title">
      <a class="navbar-brand" href="/">
        <h1>Pricewatcher</h1>
      </a>
    </div>

    <ul class="profile-menu">
      <li>
        <% if (user) { %>
          <a class="navbar-account-button btn-icon <%= navItem === 'profile' ? 'navbar-account-button-active' : '' %>" href="/profile" aria-label="Profile"></a>
        <% } else { %>
          <a class="navbar-item <%= navItem === 'login' ? 'navbar-highlight' : 'nav-link' %>" href="/auth/login">Login</a>
        <% } %>
      </li>
    </ul>
  </div>

  <div class="mobile-nav-panel">
    <div class="mobile-nav-panel-inner">
      <ul class="menu menu-mobile">
        <% navLinks.forEach((link) => { %>
          <li>
            <a class="navbar-item <%= navItem === link.key ? 'navbar-highlight' : 'nav-link' %>" href="<%= link.href %>"><%= link.label %></a>
          </li>
        <% }); %>
      </ul>
    </div>
  </div>
</nav>

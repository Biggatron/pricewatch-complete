<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('./partials/head'); %>
</head>
<body class="body-container">

<header>
  <%- include('./partials/header', { navItem: 'profile' }); %>
</header>

<main class="themed-main">
  <section class="page-shell page-shell-narrow">
    <div class="page-card page-card-split">
      <div class="page-copy">
        <p class="page-kicker">Your account</p>
        <h1 class="page-title">Hello, <%= user.name.split(' ').shift() %></h1>
        <p class="page-intro">
          Manage where your price alerts arrive and keep your account details ready for the next drop.
        </p>

        <div class="page-stat-grid">
          <article class="page-stat-card">
            <span class="page-stat-label">Current email</span>
            <strong class="page-stat-value"><%= user.email %></strong>
          </article>
          <article class="page-stat-card">
            <span class="page-stat-label">Notifications</span>
            <strong class="page-stat-value">Price change emails are enabled</strong>
          </article>
        </div>

        <div class="theme-actions">
          <a href="/auth/logout" class="btn-secondary">Logout</a>
        </div>
      </div>

      <div class="page-card-panel">
        <h2 class="page-section-title">Notification email</h2>
        <p class="page-note">Use the address below to receive price change alerts and account updates.</p>

        <form class="theme-form" id="update-email-form">
          <label class="theme-field" for="email">
            <span class="theme-label">Email address</span>
            <input
              class="theme-input"
              type="email"
              id="email"
              name="email"
              value="<%= user.email %>"
              placeholder="Enter your email"
              required>
          </label>

          <button type="submit" class="btn">Update email</button>
        </form>

        <p id="email-update-status" class="theme-status display-none"></p>
      </div>
    </div>
  </section>
</main>

<footer>
  <%- include('./partials/footer'); %>
</footer>

<script>
  const emailUpdateStatusEl = document.getElementById('email-update-status');

  function setEmailUpdateStatus(message, type = 'success') {
    emailUpdateStatusEl.textContent = message || '';
    emailUpdateStatusEl.classList.toggle('display-none', !message);
    emailUpdateStatusEl.classList.toggle('theme-status-success', Boolean(message) && type === 'success');
    emailUpdateStatusEl.classList.toggle('theme-status-error', Boolean(message) && type === 'error');
  }

  document.getElementById('update-email-form').addEventListener('submit', async (event) => {
    event.preventDefault();

    const email = document.getElementById('email').value;
    setEmailUpdateStatus('');

    try {
      const response = await fetch('/profile/update-user-email', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ newEmail: email }),
      });

      if (response.ok) {
        setEmailUpdateStatus('Email updated successfully!', 'success');
      } else {
        const errorData = await response.json();
        setEmailUpdateStatus(errorData.message || 'Failed to update email.', 'error');
      }
    } catch (error) {
      console.error('Error updating email:', error);
      setEmailUpdateStatus('An error occurred while updating the email.', 'error');
    }
  });
</script>

</body>
</html>

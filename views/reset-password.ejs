<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('./partials/head'); %>
</head>
<body class="body-container">

<header>
  <%- include('./partials/header', {navItem: 'login'}); %>
</header>

<main class="themed-main">
  <section class="page-shell page-shell-narrow">
    <div class="page-card page-card-split">
      <div class="page-copy">
        <p class="page-kicker">Choose a new password</p>
        <h1 class="page-title">Set your new password</h1>
        <p class="page-intro">
          Pick a strong password so you can get back to tracking products without interruptions.
        </p>
      </div>

      <div class="page-card-panel">
        <% if (isValidToken) { %>
          <div class="theme-form">
            <label class="theme-field" for="new-password">
              <span class="theme-label">New password</span>
              <input class="theme-input" id="new-password" type="password" autocomplete="new-password" placeholder="At least 8 characters">
            </label>

            <label class="theme-field" for="new-password-repeated">
              <span class="theme-label">Repeat password</span>
              <input class="theme-input" id="new-password-repeated" type="password" autocomplete="new-password" placeholder="Repeat your new password">
            </label>

            <p id="reset-password-status" class="theme-status display-none"></p>

            <button class="btn-google-blue" type="button" onClick="resetPassword()">Reset password</button>
          </div>
        <% } else { %>
          <p id="reset-password-status" class="theme-status theme-status-error"><%= message %></p>
        <% } %>

        <div class="theme-links">
          <p><a class="text-link" href="/auth/login">Back to login</a></p>
        </div>
      </div>
    </div>
  </section>
</main>

<footer>
  <%- include('./partials/footer'); %>
</footer>

</body>
</html>

<script>
  let loaderEl = document.getElementById('loader');
  let resetPasswordStatusEl = document.getElementById('reset-password-status');
  let resetToken = '<%= resetToken || "" %>';
  let isValidToken = <%- JSON.stringify(Boolean(isValidToken)) %>;

  function showLoader() {
    loaderEl.classList.remove('display-none');
  }

  function hideLoader() {
    loaderEl.classList.add('display-none');
  }

  function setResetStatus(message, type = 'error') {
    resetPasswordStatusEl.innerText = message || '';
    resetPasswordStatusEl.classList.toggle('display-none', !message);
    resetPasswordStatusEl.classList.toggle('theme-status-error', Boolean(message) && type === 'error');
    resetPasswordStatusEl.classList.toggle('theme-status-success', Boolean(message) && type === 'success');
  }

  function resetPassword() {
    if (!isValidToken) {
      return;
    }

    const password = document.getElementById('new-password').value;
    const passwordRepeated = document.getElementById('new-password-repeated').value;

    setResetStatus('');

    if (password !== passwordRepeated) {
      setResetStatus('Passwords do not match.', 'error');
      return;
    }

    if (password.length < 8) {
      setResetStatus('Password must be at least 8 characters long.', 'error');
      return;
    }

    showLoader();
    postData('/auth/reset-password', {
      token: resetToken,
      password: password
    }).then((response) => {
      hideLoader();
      setResetStatus(response.message, 'success');
      window.setTimeout(() => {
        window.location.href = '/auth/login?message=password_reset';
      }, 800);
    }).catch((error) => {
      hideLoader();
      setResetStatus(error, 'error');
    });
  }
</script>

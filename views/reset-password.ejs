<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('./partials/head'); %>
</head>
<body class="body-container">

<header>
  <%- include('./partials/header', {navItem: 'login'}); %>
</header>

<main>
  <div class="content-container">
    <div class="center-col-container">
      <% if (isValidToken) { %>
        <div class="center-col-container">
          <div>
            <input class="input-text" id="new-password" type="password" autocomplete="new-password" placeholder="New password">
          </div>
          <div>
            <input class="input-text" id="new-password-repeated" type="password" autocomplete="new-password" placeholder="Repeat new password">
          </div>
          <p id="reset-password-status" style="color:red;"></p>
          <button class="btn-google-blue" onClick="resetPassword()">Reset password</button>
        </div>
      <% } else { %>
        <p id="reset-password-status" style="color:red;"><%= message %></p>
      <% } %>
      <p><a href="/auth/login">Back to login</a></p>
    </div>
  </div>
</main>

<footer>
  <%- include('./partials/footer'); %>
</footer>

</body>
</html>

<script>
  let loaderEl = document.getElementById('loader');
  let resetPasswordStatusEl = document.getElementById('reset-password-status');
  let resetToken = '<%= resetToken || "" %>';
  let isValidToken = <%- JSON.stringify(Boolean(isValidToken)) %>;

  function showLoader() {
    loaderEl.classList.remove('display-none');
  }

  function hideLoader() {
    loaderEl.classList.add('display-none');
  }

  function resetPassword() {
    if (!isValidToken) {
      return;
    }

    const password = document.getElementById('new-password').value;
    const passwordRepeated = document.getElementById('new-password-repeated').value;

    resetPasswordStatusEl.style.color = 'red';
    resetPasswordStatusEl.innerText = '';

    if (password !== passwordRepeated) {
      resetPasswordStatusEl.innerText = 'Passwords do not match.';
      return;
    }

    if (password.length < 8) {
      resetPasswordStatusEl.innerText = 'Password must be at least 8 characters long.';
      return;
    }

    showLoader();
    postData('/auth/reset-password', {
      token: resetToken,
      password: password
    }).then((response) => {
      hideLoader();
      resetPasswordStatusEl.style.color = 'green';
      resetPasswordStatusEl.innerText = response.message;
      window.setTimeout(() => {
        window.location.href = '/auth/login?message=password_reset';
      }, 800);
    }).catch((error) => {
      hideLoader();
      resetPasswordStatusEl.style.color = 'red';
      resetPasswordStatusEl.innerText = error;
    });
  }
</script>
